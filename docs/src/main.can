        * "fullstack" => Pager {
            Html(`<nav class="pager">{Slug("markdown-web") -> Prev(Label("Docs Site in the Browser")) -> String}{Slug("stdlib") -> Next(Label("Standard Library")) -> String}</nav>`)
        }
        * "functions" => Pager {
            Html(`<nav class="pager">{Slug("expressions") -> Prev(Label("Expressions &amp; Dispatch")) -> String}{Slug("ordering") -> Next(Label("Ordering Rules")) -> String}</nav>`)
        }
        * "guide" => Pager {
            Html(`<nav class="pager">{Slug("building-and-running") -> Prev(Label("Building &amp; Running")) -> String}{Slug("canon-for-ai") -> Next(Label("Canon for AI")) -> String}</nav>`)
        }
        * "hello-world" => Pager {
            Html(`<nav class="pager">{Slug("installation") -> Prev(Label("Installation")) -> String}{Slug("building-and-running") -> Next(Label("Building &amp; Running")) -> String}</nav>`)
        }
        * "installation" => Pager {
            Html(`<nav class="pager">{Slug("introduction") -> Prev(Label("Introduction")) -> String}{Slug("hello-world") -> Next(Label("Hello, World")) -> String}</nav>`)
        }
        * "lexical-structure" => Pager {
            Html(`<nav class="pager">{Slug("overview") -> Prev(Label("Overview")) -> String}{Slug("types") -> Next(Label("Types")) -> String}</nav>`)
