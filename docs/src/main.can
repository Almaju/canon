Body = Html

Content = Html

Init = Model

Label = String

Model = Page * Query

Msg = String

NavItem = Html

Next = Html

Page = String

Pager = Html

Prev = Html

Query = String

Slug = String

Update = Model

Model => Body {
    Model.Query -> Eq("") -> (
        * False => Body { Model.Query -> Results }
        * True => Body {
            Model.Page
                -> Content
                -> String
                -> Joined(Model.Page -> Pager -> String)
                -> Html
        }
    )
}

Page => Content {
    Page -> (
        * "async-without-keywords" => Content { AsyncWithoutKeywords() -> Html }
        * "branching-and-loops" => Content { BranchingAndLoops() -> Html }
        * "building-and-running" => Content { BuildingAndRunning() -> Html }
        * "canon-for-ai" => Content { CanonForAi() -> Html }
        * "capabilities" => Content { Capabilities() -> Html }
        * "codegen-gaps" => Content { CodegenGaps() -> Html }
        * "coming-from" => Content { ComingFrom() -> Html }
        * "compilation" => Content { Compilation() -> Html }
        * "contributing" => Content { Contributing() -> Html }
        * "deploying" => Content { Deploying() -> Html }
        * "effects-and-async" => Content { EffectsAndAsync() -> Html }
        * "errors-and-options" => Content { ErrorsAndOptions() -> Html }
        * "expressions" => Content { Expressions() -> Html }
        * "fullstack" => Content { Fullstack() -> Html }
        * "functions" => Content { Functions() -> Html }
        * "hello-world" => Content { HelloWorld() -> Html }
        * "how-do-i" => Content { HowDoI() -> Html }
        * "installation" => Content { Installation() -> Html }
        * "lexical-structure" => Content { LexicalStructure() -> Html }
        * "markdown-renderer" => Content { MarkdownRenderer() -> Html }
        * "markdown-web" => Content { MarkdownWeb() -> Html }
        * "modules" => Content { Modules() -> Html }
        * "multifile" => Content { Multifile() -> Html }
        * "notes-api" => Content { NotesApi() -> Html }
        * "ordering" => Content { Ordering() -> Html }
        * "overview" => Content { Overview() -> Html }
        * "philosophy" => Content { Philosophy() -> Html }
        * "pipes-and-constructors" => Content { PipesAndConstructors() -> Html }
        * "programs-and-modules" => Content { ProgramsAndModules() -> Html }
        * "showcase" => Content { Showcase() -> Html }
        * "stdlib" => Content { Stdlib() -> Html }
        * "testing" => Content { Testing() -> Html }
        * "todolist" => Content { Todolist() -> Html }
        * "types" => Content { Types() -> Html }
        * "types-and-values" => Content { TypesAndValues() -> Html }
        * "types-only" => Content { TypesOnly() -> Html }
        * "wasi" => Content { Wasi() -> Html }
        * "web-target" => Content { WebTarget() -> Html }
        * String => Content { Introduction() -> Html }
    )
}

Model => Html {
    <div class="app">
        {Styles()}
        <aside class="side">
            <a class="brand" data-msg="Nav:introduction"><b>&#10033;</b> canon</a>
            <form class="search" data-msg-form="Find:"><input type="search" name="q" placeholder="Search the docs…" aria-label="Search the docs" autocomplete="off"></form>
            <div class="sec">Start</div>
            {Model.Page -> NavItem(Slug("introduction") * Label("Why Canon"))}
            {Model.Page -> NavItem(Slug("philosophy") * Label("The Philosophy"))}
            {Model.Page -> NavItem(Slug("coming-from") * Label("Is Canon for You?"))}
            {Model.Page -> NavItem(Slug("canon-for-ai") * Label("Canon for AI"))}
            {Model.Page -> NavItem(Slug("installation") * Label("Installation"))}
            {Model.Page -> NavItem(Slug("hello-world") * Label("Hello, World"))}
            <div class="sec">Learn</div>
            {Model.Page -> NavItem(Slug("types-and-values") * Label("Types &amp; Values"))}
            {
                Model.Page
                    -> NavItem(Slug("pipes-and-constructors") * Label("Pipes &amp; Constructors"))
            }
            {Model.Page -> NavItem(Slug("branching-and-loops") * Label("Branching &amp; Loops"))}
            {Model.Page -> NavItem(Slug("errors-and-options") * Label("Errors &amp; Options"))}
            {Model.Page -> NavItem(Slug("capabilities") * Label("Capabilities"))}
            {Model.Page -> NavItem(Slug("async-without-keywords") * Label("Async"))}
            {Model.Page -> NavItem(Slug("programs-and-modules") * Label("Programs &amp; Modules"))}
            {Model.Page -> NavItem(Slug("testing") * Label("Testing"))}
            {Model.Page -> NavItem(Slug("how-do-i") * Label("How Do I&#8230;?"))}
            <div class="sec">Examples</div>
            {Model.Page -> NavItem(Slug("showcase") * Label("Overview"))}
            {Model.Page -> NavItem(Slug("multifile") * Label("Multi-File Project"))}
            {Model.Page -> NavItem(Slug("notes-api") * Label("notes-api: JSON Service"))}
            {Model.Page -> NavItem(Slug("todolist") * Label("Todo List in the Browser"))}
            {Model.Page -> NavItem(Slug("markdown-web") * Label("Docs Site in the Browser"))}
            {Model.Page -> NavItem(Slug("fullstack") * Label("Fullstack"))}
            <div class="sec">Reference</div>
            {Model.Page -> NavItem(Slug("stdlib") * Label("Standard Library"))}
            {Model.Page -> NavItem(Slug("markdown-renderer") * Label("Markdown"))}
            {Model.Page -> NavItem(Slug("wasi") * Label("WASI Interfaces"))}
            {Model.Page -> NavItem(Slug("web-target") * Label("The Web Target"))}
            {Model.Page -> NavItem(Slug("building-and-running") * Label("The canon CLI"))}
            {Model.Page -> NavItem(Slug("deploying") * Label("Deploying"))}
            {Model.Page -> NavItem(Slug("codegen-gaps") * Label("Known Codegen Gaps"))}
            <div class="sec">Specification</div>
            {Model.Page -> NavItem(Slug("overview") * Label("Overview"))}
            {Model.Page -> NavItem(Slug("lexical-structure") * Label("Lexical Structure"))}
            {Model.Page -> NavItem(Slug("types") * Label("Types"))}
            {Model.Page -> NavItem(Slug("expressions") * Label("Expressions &amp; Dispatch"))}
            {Model.Page -> NavItem(Slug("functions") * Label("Functions &amp; Traits"))}
            {Model.Page -> NavItem(Slug("ordering") * Label("Ordering Rules"))}
            {Model.Page -> NavItem(Slug("modules") * Label("Modules &amp; Packages"))}
            {Model.Page -> NavItem(Slug("effects-and-async") * Label("Effects &amp; Async"))}
            {Model.Page -> NavItem(Slug("compilation") * Label("Compilation &amp; ABI"))}
            {Model.Page -> NavItem(Slug("types-only") * Label("Types-Only Canon"))}
            <div class="sec">Project</div>
            {Model.Page -> NavItem(Slug("contributing") * Label("Contributing"))}
        </aside>
        <main class="main"><article class="doc">{Model -> Body}</article></main>
    </div>
}

Unit => Init {
    Page("introduction") -> Model(Query(""))
}

Page * Slug * Label => NavItem {
    Page.String -> Eq(Slug.String) -> (
        * False => NavItem { Html(`<button data-msg="Nav:{Slug.String}">{Label.String}</button>`) }
        * True => NavItem {
            Html(`<button class="active" aria-current="page" data-msg="Nav:{Slug.String}">{Label.String}</button>`)
        }
    )
}

Slug * Label => Next {
    Html(`<a class="pager-link pager-next" data-msg="Nav:{Slug.String}"><span class="pager-dir">Next &#8594;</span><span class="pager-title">{Label.String}</span></a>`)
}

