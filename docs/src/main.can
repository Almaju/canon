Slug * Label => Prev {
    "<a class=\"pager-link pager-prev\" data-msg=\"Nav:"
        -> Joined(Slug.String)
        -> Joined("\"><span class=\"pager-dir\">&#8592; Previous</span><span class=\"pager-title\">")
        -> Joined(Label.String)
        -> Joined("</span></a>")
        -> Html
}

Page * Msg => Update {
    Msg -> Substring(1 -> From * 4 -> To) -> (
        * "Nav:" => Page { Msg -> Substring(5 -> From * Msg -> Length -> To) -> Page }
        * String => Page { Page }
    )
}
