        }
        * "modules" => Pager {
            Html(`<nav class="pager">{Slug("ordering") -> Prev(Label("Ordering Rules")) -> String}{Slug("effects-and-async") -> Next(Label("Effects &amp; Async")) -> String}</nav>`)
        }
