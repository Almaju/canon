        * "compilation" => Pager {
            Html(`<nav class="pager">{Slug("effects-and-async") -> Prev(Label("Effects &amp; Async")) -> String}{Slug("types-only") -> Next(Label("Types-Only Canon")) -> String}</nav>`)
        }
        * "contributing" => Pager {
            Html(`<nav class="pager">{Slug("coming-from") -> Prev(Label("Coming from Another Language")) -> String}</nav>`)
