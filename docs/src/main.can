        * "effects-and-async" => Pager {
            Html(`<nav class="pager">{Slug("modules") -> Prev(Label("Modules &amp; Packages")) -> String}{Slug("compilation") -> Next(Label("Compilation &amp; ABI")) -> String}</nav>`)
