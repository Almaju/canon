Content = Html

Init = Page

Label = String

Msg = String

NavItem = Html

Next = Html

Page = String

Pager = Html

Prev = Html

Slug = String

Update = Page

Page => Content {
    Page -> (
        * "building-and-running" => Content { BuildingAndRunning() -> Html }
        * "canon-for-ai" => Content { CanonForAi() -> Html }
        * "codegen-gaps" => Content { CodegenGaps() -> Html }
        * "coming-from" => Content { ComingFrom() -> Html }
        * "compilation" => Content { Compilation() -> Html }
        * "contributing" => Content { Contributing() -> Html }
        * "deploying" => Content { Deploying() -> Html }
        * "effects-and-async" => Content { EffectsAndAsync() -> Html }
        * "expressions" => Content { Expressions() -> Html }
        * "fullstack" => Content { Fullstack() -> Html }
        * "functions" => Content { Functions() -> Html }
        * "guide" => Content { Guide() -> Html }
        * "hello-world" => Content { HelloWorld() -> Html }
        * "installation" => Content { Installation() -> Html }
        * "lexical-structure" => Content { LexicalStructure() -> Html }
        * "markdown-renderer" => Content { MarkdownRenderer() -> Html }
        * "markdown-web" => Content { MarkdownWeb() -> Html }
        * "modules" => Content { Modules() -> Html }
        * "multifile" => Content { Multifile() -> Html }
        * "notes-api" => Content { NotesApi() -> Html }
        * "ordering" => Content { Ordering() -> Html }
        * "overview" => Content { Overview() -> Html }
        * "showcase" => Content { Showcase() -> Html }
        * "stdlib" => Content { Stdlib() -> Html }
        * "todolist" => Content { Todolist() -> Html }
        * "types" => Content { Types() -> Html }
        * "types-only" => Content { TypesOnly() -> Html }
        * "wasi" => Content { Wasi() -> Html }
        * "web-target" => Content { WebTarget() -> Html }
        * String => Content { Introduction() -> Html }
    )
}

Page => Html {
    <div class="app">
        {Styles()}
        <aside class="side">
            <a class="brand" data-msg="Nav:introduction"><b>&#10033;</b> canon</a>
            <div class="sec">Start</div>
            {Page -> NavItem(Slug("introduction") * Label("Introduction"))}
            {Page -> NavItem(Slug("installation") * Label("Installation"))}
            {Page -> NavItem(Slug("hello-world") * Label("Hello, World"))}
            {Page -> NavItem(Slug("building-and-running") * Label("Building &amp; Running"))}
            {Page -> NavItem(Slug("guide") * Label("A Tour of Canon"))}
            {Page -> NavItem(Slug("canon-for-ai") * Label("Canon for AI"))}
            <div class="sec">Specification</div>
            {Page -> NavItem(Slug("overview") * Label("Overview"))}
            {Page -> NavItem(Slug("lexical-structure") * Label("Lexical Structure"))}
            {Page -> NavItem(Slug("types") * Label("Types"))}
            {Page -> NavItem(Slug("expressions") * Label("Expressions &amp; Dispatch"))}
            {Page -> NavItem(Slug("functions") * Label("Functions &amp; Traits"))}
            {Page -> NavItem(Slug("ordering") * Label("Ordering Rules"))}
            {Page -> NavItem(Slug("modules") * Label("Modules &amp; Packages"))}
            {Page -> NavItem(Slug("effects-and-async") * Label("Effects &amp; Async"))}
            {Page -> NavItem(Slug("compilation") * Label("Compilation &amp; ABI"))}
            {Page -> NavItem(Slug("types-only") * Label("Types-Only Canon"))}
            <div class="sec">Examples</div>
            {Page -> NavItem(Slug("showcase") * Label("Overview"))}
            {Page -> NavItem(Slug("multifile") * Label("Multi-File Project"))}
            {Page -> NavItem(Slug("notes-api") * Label("notes-api: JSON Service"))}
            {Page -> NavItem(Slug("todolist") * Label("Todo List in the Browser"))}
            {Page -> NavItem(Slug("markdown-web") * Label("Docs Site in the Browser"))}
            {Page -> NavItem(Slug("fullstack") * Label("Fullstack"))}
            <div class="sec">Reference</div>
            {Page -> NavItem(Slug("stdlib") * Label("Standard Library"))}
            {Page -> NavItem(Slug("markdown-renderer") * Label("Markdown"))}
            {Page -> NavItem(Slug("wasi") * Label("WASI Interfaces"))}
            {Page -> NavItem(Slug("web-target") * Label("The Web Target"))}
            {Page -> NavItem(Slug("codegen-gaps") * Label("Known Codegen Gaps"))}
            {Page -> NavItem(Slug("deploying") * Label("Deploying"))}
            {Page -> NavItem(Slug("coming-from") * Label("Coming from Another Language"))}
            <div class="sec">Project</div>
            {Page -> NavItem(Slug("contributing") * Label("Contributing"))}
        </aside>
        <main class="main"><article class="doc">{Page -> Content}{Page -> Pager}</article></main>
    </div>
}

Unit => Init {
    Page("introduction")
}

Page * Slug * Label => NavItem {
    Page.String -> Eq(Slug.String) -> (
        * False => NavItem { Html(`<button data-msg="Nav:{Slug.String}">{Label.String}</button>`) }
        * True => NavItem {
            Html(`<button class="active" aria-current="page" data-msg="Nav:{Slug.String}">{Label.String}</button>`)
        }
    )
}

Slug * Label => Next {
    Html(`<a class="pager-link pager-next" data-msg="Nav:{Slug.String}"><span class="pager-dir">Next &#8594;</span><span class="pager-title">{Label.String}</span></a>`)
}

Page => Pager {
    Page -> (
        * "building-and-running" => Pager {
            Html(`<nav class="pager">{Slug("hello-world") -> Prev(Label("Hello, World")) -> String}{Slug("guide") -> Next(Label("A Tour of Canon")) -> String}</nav>`)
        }
        * "canon-for-ai" => Pager {
            Html(`<nav class="pager">{Slug("guide") -> Prev(Label("A Tour of Canon")) -> String}{Slug("overview") -> Next(Label("Overview")) -> String}</nav>`)
        }
        * "codegen-gaps" => Pager {
            Html(`<nav class="pager">{Slug("web-target") -> Prev(Label("The Web Target")) -> String}{Slug("deploying") -> Next(Label("Deploying")) -> String}</nav>`)
        }
        * "coming-from" => Pager {
            Html(`<nav class="pager">{Slug("deploying") -> Prev(Label("Deploying")) -> String}{Slug("contributing") -> Next(Label("Contributing")) -> String}</nav>`)
