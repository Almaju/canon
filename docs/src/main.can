Content = Html

Init = Page

Label = String

Msg = String

NavItem = Html

Next = Html

Page = String

Pager = Html

Prev = Html

Slug = String

Update = Page

Page => Content {
    Page -> (
        * "building-and-running" => Content { BuildingAndRunning() -> Html }
        * "canon-for-ai" => Content { CanonForAi() -> Html }
        * "codegen-gaps" => Content { CodegenGaps() -> Html }
        * "coming-from" => Content { ComingFrom() -> Html }
        * "compilation" => Content { Compilation() -> Html }
        * "contributing" => Content { Contributing() -> Html }
        * "deploying" => Content { Deploying() -> Html }
        * "effects-and-async" => Content { EffectsAndAsync() -> Html }
        * "expressions" => Content { Expressions() -> Html }
        * "fullstack" => Content { Fullstack() -> Html }
        * "functions" => Content { Functions() -> Html }
        * "guide" => Content { Guide() -> Html }
        * "hello-world" => Content { HelloWorld() -> Html }
        * "installation" => Content { Installation() -> Html }
        * "lexical-structure" => Content { LexicalStructure() -> Html }
        * "markdown-renderer" => Content { MarkdownRenderer() -> Html }
        * "markdown-web" => Content { MarkdownWeb() -> Html }
        * "modules" => Content { Modules() -> Html }
        * "multifile" => Content { Multifile() -> Html }
        * "notes-api" => Content { NotesApi() -> Html }
        * "ordering" => Content { Ordering() -> Html }
        * "overview" => Content { Overview() -> Html }
        * "showcase" => Content { Showcase() -> Html }
        * "stdlib" => Content { Stdlib() -> Html }
        * "todolist" => Content { Todolist() -> Html }
        * "types" => Content { Types() -> Html }
        * "types-only" => Content { TypesOnly() -> Html }
        * "wasi" => Content { Wasi() -> Html }
        * "web-target" => Content { WebTarget() -> Html }
        * String => Content { Introduction() -> Html }
    )
}

Page => Html {
    <div class="app">
        {Styles()}
        <aside class="side">
            <a class="brand" data-msg="Nav:introduction"><b>&#10033;</b> canon</a>
            <div class="sec">Start</div>
            {Page -> NavItem("introduction" -> Slug * "Introduction" -> Label)}
            {Page -> NavItem("installation" -> Slug * "Installation" -> Label)}
            {Page -> NavItem("hello-world" -> Slug * "Hello, World" -> Label)}
            {Page -> NavItem("building-and-running" -> Slug * "Building &amp; Running" -> Label)}
            {Page -> NavItem("guide" -> Slug * "A Tour of Canon" -> Label)}
            {Page -> NavItem("canon-for-ai" -> Slug * "Canon for AI" -> Label)}
            <div class="sec">Specification</div>
            {Page -> NavItem("overview" -> Slug * "Overview" -> Label)}
            {Page -> NavItem("lexical-structure" -> Slug * "Lexical Structure" -> Label)}
            {Page -> NavItem("types" -> Slug * "Types" -> Label)}
            {Page -> NavItem("expressions" -> Slug * "Expressions &amp; Dispatch" -> Label)}
            {Page -> NavItem("functions" -> Slug * "Functions &amp; Traits" -> Label)}
            {Page -> NavItem("ordering" -> Slug * "Ordering Rules" -> Label)}
            {Page -> NavItem("modules" -> Slug * "Modules &amp; Packages" -> Label)}
            {Page -> NavItem("effects-and-async" -> Slug * "Effects &amp; Async" -> Label)}
            {Page -> NavItem("compilation" -> Slug * "Compilation &amp; ABI" -> Label)}
            {Page -> NavItem("types-only" -> Slug * "Types-Only Canon" -> Label)}
            <div class="sec">Examples</div>
            {Page -> NavItem("showcase" -> Slug * "Overview" -> Label)}
            {Page -> NavItem("multifile" -> Slug * "Multi-File Project" -> Label)}
            {Page -> NavItem("notes-api" -> Slug * "notes-api: JSON Service" -> Label)}
            {Page -> NavItem("todolist" -> Slug * "Todo List in the Browser" -> Label)}
            {Page -> NavItem("markdown-web" -> Slug * "Docs Site in the Browser" -> Label)}
            {Page -> NavItem("fullstack" -> Slug * "Fullstack" -> Label)}
            <div class="sec">Reference</div>
            {Page -> NavItem("stdlib" -> Slug * "Standard Library" -> Label)}
            {Page -> NavItem("markdown-renderer" -> Slug * "Markdown" -> Label)}
            {Page -> NavItem("wasi" -> Slug * "WASI Interfaces" -> Label)}
            {Page -> NavItem("web-target" -> Slug * "The Web Target" -> Label)}
            {Page -> NavItem("codegen-gaps" -> Slug * "Known Codegen Gaps" -> Label)}
            {Page -> NavItem("deploying" -> Slug * "Deploying" -> Label)}
            {Page -> NavItem("coming-from" -> Slug * "Coming from Another Language" -> Label)}
            <div class="sec">Project</div>
            {Page -> NavItem("contributing" -> Slug * "Contributing" -> Label)}
        </aside>
        <main class="main"><article class="doc">{Page -> Content}{Page -> Pager}</article></main>
    </div>
}

Unit => Init {
    "introduction" -> Page
}

Page * Slug * Label => NavItem {
    Page.String -> Eq(Slug.String) -> (
        * False => NavItem {
            "<button data-msg=\"Nav:"
                -> Joined(Slug.String)
                -> Joined("\">")
                -> Joined(Label.String)
                -> Joined("</button>")
                -> Html
        }
        * True => NavItem {
            "<button class=\"active\" aria-current=\"page\" data-msg=\"Nav:"
                -> Joined(Slug.String)
                -> Joined("\">")
                -> Joined(Label.String)
                -> Joined("</button>")
                -> Html
        }
    )
}

Slug * Label => Next {
    "<a class=\"pager-link pager-next\" data-msg=\"Nav:"
        -> Joined(Slug.String)
        -> Joined("\"><span class=\"pager-dir\">Next &#8594;</span><span class=\"pager-title\">")
        -> Joined(Label.String)
        -> Joined("</span></a>")
        -> Html
}

