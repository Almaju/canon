Slug * Label => Prev {
    Html(`<a class="pager-link pager-prev" data-msg="Nav:{Slug.String}"><span class="pager-dir">&#8592; Previous</span><span class="pager-title">{Label.String}</span></a>`)
}

Page * Msg => Update {
    Msg -> Substring(From(1) * To(4)) -> (
        * "Nav:" => Page { Msg -> Substring(From(5) * Msg -> Length -> To) -> Page }
        * String => Page { Page }
    )
}
