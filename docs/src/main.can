Body = Html

Content = Html

Init = Model

Label = String

Model = Page * Query

Msg = String

NavItem = Html

Next = Html

Page = String

Pager = Html

Prev = Html

Query = String

Slug = String

Update = Model

Model => Body {
    Model.Query -> Eq("") -> (
        * False => Body { Model.Query -> Results }
        * True => Body {
            Model.Page
                -> Content
                -> String
                -> Joined(Model.Page -> Pager -> String)
                -> Html
        }
    )
}

