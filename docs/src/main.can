Slug * Label => Prev {
    Html(`<a class="pager-link pager-prev" data-msg="Nav:{Slug.String}"><span class="pager-dir">&#8592; Previous</span><span class="pager-title">{Label.String}</span></a>`)
}

Model * Msg => Update {
    Msg -> Substring(From(1) * To(4)) -> (
        * "Find" => Model {
            Model.Page -> Model(Msg -> Substring(From(6) * Msg -> Length -> To) -> Query)
        }
        * "Nav:" => Model {
            Msg
                -> Substring(From(5) * Msg -> Length -> To)
                -> Page
                -> Model(Query(""))
        }
        * String => Model { Model }
    )
}
