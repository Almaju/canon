            Html(`<nav class="pager">{Slug("notes-api") -> Prev(Label("notes-api: JSON Service")) -> String}{Slug("markdown-web") -> Next(Label("Docs Site in the Browser")) -> String}</nav>`)
        }
        * "types" => Pager {
            Html(`<nav class="pager">{Slug("lexical-structure") -> Prev(Label("Lexical Structure")) -> String}{Slug("expressions") -> Next(Label("Expressions &amp; Dispatch")) -> String}</nav>`)
