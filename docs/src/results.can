String * Needle * Start => Holds {
    Start -> Gt(String -> Length) -> (
        * False => Holds {
            String -> LineHolds(Needle * Start * String -> Stop(Start)) -> (
                * False => Holds {
                    String -> Holds(Needle * String -> Stop(Start) -> Sum(1) -> Start)
                }
                * True => Holds { True() }
            )
        }
        * True => Holds { False() }
    )
}

String * Needle * Start * Stop => LineHolds {
    Start -> Sum(Needle -> Length -> Difference(1)) -> Gt(Stop -> Difference(1)) -> (
        * False => LineHolds {
            String -> PrefixMatch(Needle * Start * Step(1)) -> (
                * False => LineHolds {
                    String -> LineHolds(Needle * Start -> Sum(1) -> Start * Stop)
                }
                * True => LineHolds { True() }
            )
        }
        * True => LineHolds { False() }
    )
}

Int => Lowered {
    Int -> Ge(65) -> (
        * False => Lowered { Int }
        * True => Lowered {
            Int -> Le(90) -> (
                * False => Lowered { Int }
                * True => Lowered { Int -> Sum(32) }
            )
        }
    )
}

String * Needle * Start * Step => PrefixMatch {
    Step -> Gt(Needle -> Length) -> (
        * False => PrefixMatch {
            String
                -> ByteAt(Start -> Sum(Step) -> Difference(1))
                -> Lowered
                -> Eq(Needle -> ByteAt(Step) -> Lowered) -> (
                * False => PrefixMatch { False() }
                * True => PrefixMatch {
                    String -> PrefixMatch(Needle * Start * Step -> Sum(1) -> Step)
                }
            )
        }
        * True => PrefixMatch { True() }
    )
}

Query => Results {
    Query -> Hits -> String -> Length -> Eq(0) -> (
        * False => Results {
            <div class="results"><div class="results-head">Matches for “{Query -> String}”</div>{Query -> Hits}</div>
        }
        * True => Results {
            <div class="results"><div class="results-head">No matches for “{Query -> String}”</div></div>
        }
    )
}

String * Start => Stop {
    Start -> Gt(String -> Length) -> (
        * False => Stop {
            String -> ByteAt(Start) -> Eq(10) -> (
                * False => Stop { String -> Stop(Start -> Sum(1) -> Start) }
                * True => Stop { Start }
            )
        }
        * True => Stop { Start }
    )
}
