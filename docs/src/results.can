Hit = Html

Hits = Html

Holds = Bool

LineHolds = Bool

Lowered = Int

Needle = String

PrefixMatch = Bool

Results = Html

Start = Int

Step = Int

Stop = Int

Text = String

Query * Slug * Label * Text => Hit {
    Text.String -> Holds(Query.String -> Needle * Start(1)) -> (
        * False => Hit { Html("") }
        * True => Hit {
            "<button class=\"result\" data-msg=\"Nav:"
                -> Joined(Slug.String)
                -> Joined("\">")
                -> Joined(Label.String)
                -> Joined("</button>")
                -> Html
        }
    )
}

