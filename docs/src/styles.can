Styles = Html

Unit => Styles {
    Html("<style>*{box-sizing:border-box}:root{--bg:#0a0a0a;--panel:#0e0e0f;--border:#1e1e21;--border-hi:#2c2c31;--text:#ededed;--body:#c9c9cf;--muted:#a1a1aa;--dim:#63636b;--accent:#e8a24b;--c-type:#8ad4c0;--c-op:#e8a24b;--c-str:#a9c181;--c-num:#d699b6;--sans:-apple-system,BlinkMacSystemFont,'Segoe UI','Inter',Roboto,Helvetica,Arial,sans-serif;--mono:ui-monospace,'SF Mono','JetBrains Mono',Menlo,Consolas,monospace}html{scroll-behavior:smooth}body{margin:0;background:var(--bg);color:var(--body);font:16px/1.7 var(--sans);-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}::selection{background:rgba(232,162,75,.28)}.app{display:flex;min-height:100vh;max-width:1180px;margin:0 auto}.side{width:264px;flex:none;position:sticky;top:0;align-self:flex-start;height:100vh;overflow-y:auto;border-right:1px solid var(--border);padding:22px 14px 40px;display:flex;flex-direction:column;gap:1px;scrollbar-width:thin}.brand{font-family:var(--mono);font-size:15px;font-weight:600;letter-spacing:.04em;color:var(--text);padding:4px 10px 16px;cursor:pointer;text-decoration:none;display:block}.brand b{color:var(--accent);font-weight:600;margin-right:.4em}.sec{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin:18px 0 5px;padding:0 10px}.side button{display:block;width:100%;text-align:left;background:none;color:var(--muted);border:0;border-radius:6px;padding:6px 10px;font:14px/1.4 var(--sans);cursor:pointer;transition:color .15s,background .15s}.side button:hover{color:var(--text);background:rgba(255,255,255,.05)}.side button:focus-visible{outline:2px solid var(--accent);outline-offset:-2px}.side button.active{color:var(--text);font-weight:600;background:rgba(232,162,75,.1);box-shadow:inset 2px 0 0 var(--accent)}.main{flex:1;min-width:0;display:flex;justify-content:center;padding:56px 40px 96px}.doc{width:100%;max-width:720px;min-width:0;overflow-wrap:break-word}.doc>h1:first-child,.doc>h2:first-child{margin-top:0}h1{font-size:34px;font-weight:700;letter-spacing:-.03em;line-height:1.15;margin:1.6em 0 .6em;color:var(--text);background:linear-gradient(180deg,#fff 30%,#9d9da6);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}h2{font-size:22px;font-weight:650;letter-spacing:-.02em;margin:2.4em 0 .4em;color:var(--text)}h3{font-size:17px;font-weight:650;margin:2em 0 .3em;color:var(--text)}p{margin:1em 0}strong{color:var(--text);font-weight:600}a{color:var(--accent);text-decoration:none;border-bottom:1px solid rgba(232,162,75,.3);cursor:pointer}a:hover{border-bottom-color:var(--accent)}hr{border:0;border-top:1px solid var(--border);margin:2.6em 0}ul,ol{padding-left:22px}li{margin:4px 0}li::marker{color:var(--dim)}code{font-family:var(--mono);font-size:.86em;color:var(--text);background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:5px;padding:1.5px 6px}pre{position:relative;margin:1.4em 0;border:1px solid var(--border-hi);border-radius:12px;background:linear-gradient(180deg,#101012,#0c0c0d);box-shadow:0 18px 44px -22px rgba(0,0,0,.8);overflow:hidden}pre code{display:block;padding:18px 20px;font-size:13.5px;line-height:1.7;color:var(--text);background:none;border:0;border-radius:0;overflow-x:auto;white-space:pre}blockquote{margin:1.4em 0;padding:12px 18px;border:1px solid var(--border);border-left:2px solid rgba(232,162,75,.55);border-radius:0 10px 10px 0;background:var(--panel);color:var(--muted)}blockquote p{margin:.3em 0}blockquote em{color:var(--text);font-style:normal}table{width:100%;margin:1.6em 0;border-collapse:separate;border-spacing:0;border:1px solid var(--border);border-radius:10px;overflow:hidden;font-size:14px;display:block;overflow-x:auto}thead{background:var(--panel)}th{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;text-align:left;color:var(--dim);padding:10px 14px;border-bottom:1px solid var(--border);white-space:nowrap}td{padding:9px 14px;color:var(--body);border-top:1px solid var(--border);vertical-align:top}tbody tr:first-child td{border-top:0}tbody tr:hover{background:rgba(255,255,255,.02)}::-webkit-scrollbar{width:10px;height:10px}::-webkit-scrollbar-thumb{background:var(--border-hi);border-radius:5px;border:2px solid var(--bg)}.pager{display:flex;gap:14px;margin:72px 0 0;padding-top:26px;border-top:1px solid var(--border)}.pager-link{flex:1 1 0;min-width:0;display:flex;flex-direction:column;gap:4px;padding:13px 16px;border:1px solid var(--border);border-radius:12px;background:var(--panel);text-decoration:none;transition:border-color .15s,background .15s}.pager-link:hover{border-color:var(--border-hi);background:rgba(255,255,255,.03)}.pager-next{margin-left:auto;text-align:right;align-items:flex-end}.pager-dir{font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--dim)}.pager-title{color:var(--text);font-weight:600;font-size:15px;border:0}.canon-copy-button{font:12px/1 var(--mono);color:var(--dim);border:1px solid var(--border);border-radius:7px;background:rgba(10,10,10,.62);-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);padding:5px 9px;cursor:pointer;transition:color .15s,border-color .15s}.canon-copy-button:hover{color:var(--text);border-color:var(--border-hi)}.canon-copy-ok{color:var(--c-str)}.tk-str{color:var(--c-str)}.tk-num{color:var(--c-num)}.tk-op{color:var(--c-op)}.tk-kw{color:var(--c-op);font-weight:600}.tk-type{color:var(--c-type)}.tk-ctor{color:var(--c-type)}.tk-lit{color:var(--c-num)}.tk-call{color:#6cb6ff}.tk-def{color:#6cb6ff}.canon-run-bar{position:absolute;top:7px;right:8px;z-index:1;display:flex;gap:6px}.canon-run-button{font:12px/1 var(--mono);color:var(--dim);border:1px solid var(--border);border-radius:7px;background:rgba(10,10,10,.62);-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);padding:5px 9px;cursor:pointer;transition:color .15s,border-color .15s}.canon-run-button:hover{color:var(--text);border-color:var(--border-hi)}.canon-run-glyph{color:var(--accent);font-size:9px}pre.canon-has-runner{border-radius:12px 12px 0 0;margin-bottom:0;border-bottom:0}.canon-runner{margin:0 0 1.4em;border:1px solid var(--border-hi);border-top:1px solid var(--border);border-radius:0 0 12px 12px;background:var(--bg);overflow:hidden}.canon-runner-bar{display:flex;align-items:center;gap:8px;padding:7px 14px;font:11px/1 var(--mono);letter-spacing:.1em;text-transform:uppercase;color:var(--dim);border-bottom:1px solid var(--border)}.canon-runner-bar .dot{width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent)}.canon-runner-status{margin-left:auto;text-transform:none;letter-spacing:.02em}pre.canon-runner-out{margin:0;border:0;border-radius:0;background:transparent;box-shadow:none}pre.canon-runner-out code{padding:12px 20px 14px;color:var(--muted);font-size:13px;white-space:pre-wrap}.canon-runner-err{color:#e0787d}.search{padding:2px 10px 12px}.search input{width:100%;background:var(--panel);color:var(--text);border:1px solid var(--border);border-radius:7px;padding:7px 10px;font:13px/1.4 var(--sans);outline:none;transition:border-color .15s}.search input::placeholder{color:var(--dim)}.search input:focus{border-color:var(--accent)}.results-head{font-family:var(--mono);font-size:12px;letter-spacing:.02em;color:var(--muted);margin:0 0 20px;padding-bottom:14px;border-bottom:1px solid var(--border)}.result{display:block;width:100%;text-align:left;background:var(--panel);color:var(--text);border:1px solid var(--border);border-radius:10px;padding:12px 16px;margin:0 0 8px;font:15px/1.4 var(--sans);font-weight:600;cursor:pointer;transition:border-color .15s,background .15s}.result:hover{border-color:var(--border-hi);background:rgba(255,255,255,.03)}@media(max-width:820px){.app{flex-direction:column}.search{padding:0;order:-1;flex:0 0 auto}.search input{width:160px}.side{width:auto;min-width:0;max-width:100%;height:auto;position:static;flex-direction:row;flex-wrap:nowrap;overflow-x:auto;gap:2px;border-right:0;border-bottom:1px solid var(--border);padding:10px 12px;align-items:center}.brand{padding:4px 10px;white-space:nowrap}.sec{margin:0 4px 0 12px;padding:0}.side button{width:auto;white-space:nowrap;padding:6px 10px}.side button.active{box-shadow:inset 0 -2px 0 var(--accent)}.main{padding:32px 22px 72px}h1{font-size:28px}.pager{flex-direction:column;gap:10px}.pager-next{margin-left:0;text-align:left;align-items:flex-start}}</style>")
}
