use std/TestResult

testListConstruction = () -> TestResult {
    List(1, 2, 3)
        .length()
        .eq(3)
        .assert("List(1,2,3) should have length 3")
}

testListMapPreservesLength = () -> TestResult {
    List(1, 2, 3)
        .map((Int) -> Int { Int.mul(2) })
        .length()
        .eq(3)
        .assert("map should preserve length")
}
