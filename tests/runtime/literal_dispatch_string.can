route = (String) => String {
    String -> (
        * "/notes" => String { "index" }
        * "/notes/1" => String { "note one" }
        * String => String { "not found: " -> Joined(String) }
    )
}

Unit => Program {
    "/notes"
        .route()
        -> Print
    "/notes/1"
        .route()
        -> Print
    "/oops"
        .route()
        -> Print
}
