Routed = String

String => Routed {
    String -> (
        * "/notes" => Routed { "index" }
        * "/notes/1" => Routed { "note one" }
        * String => Routed { `not found: {String}` }
    )
}

Unit => Program {
    Routed("/notes") -> Print
    Routed("/notes/1") -> Print
    Routed("/oops") -> Print
}
