Routed = String

String => Routed {
    String -> (
        * "/notes" => Routed { "index" }
        * "/notes/1" => Routed { "note one" }
        * String => Routed { "not found: " -> Joined(String) }
    )
}

Unit => Program {
    "/notes"
        -> Routed
        -> Print
    "/notes/1"
        -> Routed
        -> Print
    "/oops"
        -> Routed
        -> Print
}
