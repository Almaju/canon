route = (String) -> String {
    String.(
        * ("/notes") -> String { "index" }
        * ("/notes/1") -> String { "note one" }
        * (String) -> String { "not found: ".concat(String) }
    )
}

main = () -> Unit {
    "/notes"
        .route()
        .print()
    "/notes/1"
        .route()
        .print()
    "/oops"
        .route()
        .print()
}
