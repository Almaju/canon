Row = (String) => Html {
    <li>{String}</li>
}

Tagged = (Msg) => Html {
    <button data-msg="{Msg}">go</button>
}

Unit => Program {
    <ul>{"a & b" -> Row}{"x<y" -> Row}</ul> -> Print
    <span>{1 -> Sum(41)}</span> -> Print
    "inc"
        -> Msg
        -> Tagged
        -> Print
    <p>5 &lt; 6 &amp; 7</p> -> Print
}
