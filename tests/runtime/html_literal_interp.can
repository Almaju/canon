Row = Html

Tagged = Html

String => Row {
    <li>{String}</li>
}

Msg => Tagged {
    <button data-msg="{Msg}">go</button>
}

Unit => Program {
    <ul>{Row("a & b")}{Row("x<y")}</ul> -> Print
    <span>{1 -> Sum(41)}</span> -> Print
    Msg("inc")
        -> Tagged
        -> Print
    <p>5 &lt; 6 &amp; 7</p> -> Print
}
