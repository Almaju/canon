City = String

Home = City * Zip

Label = String

Profile = Home * Label

Zip = Int

Unit => Program {
    "paris" -> City -> Home(75 -> Zip) -> Profile("primary" -> Label).Label -> Print
    "paris" -> City -> Home(75 -> Zip) -> Profile("primary" -> Label).Home.City -> Print
    "paris" -> City -> Home(75 -> Zip) -> Profile("primary" -> Label).Home.Zip -> Print
}
