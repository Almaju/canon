City = String

Home = City * Zip

Label = String

Profile = Home * Label

Zip = Int

Unit => Program {
    City("paris") -> Home(Zip(75)) -> Profile(Label("primary")).Label -> Print
    City("paris") -> Home(Zip(75)) -> Profile(Label("primary")).Home.City -> Print
    City("paris") -> Home(Zip(75)) -> Profile(Label("primary")).Home.Zip -> Print
}
