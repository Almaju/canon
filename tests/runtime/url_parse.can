Reported = (String) => Unit {
    String -> Url -> (
        * Err<InvalidUrl> => Unit { InvalidUrl -> Print }
        * Ok<Url> => Unit { Url -> Print }
    )
}

Unit => Program {
    "http://example.com/path" -> Reported
    "https://example.com" -> Reported
    "ftp://example.com" -> Reported
    "http://" -> Reported
    "http:///path" -> Reported
    "https://x" -> Reported
}
