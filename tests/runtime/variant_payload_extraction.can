Fail = String

Pass = Unit

TestResult = Fail + Pass

MakeFail = () => TestResult {
    "the message" -> Fail
}

MakePass = () => TestResult {
    Pass()
}

Unit => Program {
    MakeFail() -> (
        * Fail => Unit { Fail -> Print }
        * Pass => Unit { "got pass" -> Print }
    )
    MakePass() -> (
        * Fail => Unit { Fail -> Print }
        * Pass => Unit { "got pass" -> Print }
    )
}
