Fail = String

Pass = Unit

TestResult = Fail + Pass

makeFail = () => TestResult {
    Fail("the message")
}

makePass = () => TestResult {
    Pass()
}

main = () => Unit {
    makeFail().(
        * (Fail) => Unit { Fail -> Print }
        * (Pass) => Unit { "got pass" -> Print }
    )
    makePass().(
        * (Fail) => Unit { Fail -> Print }
        * (Pass) => Unit { "got pass" -> Print }
    )
}
