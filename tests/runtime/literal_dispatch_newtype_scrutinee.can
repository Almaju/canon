Prefix = String

Routed = (Int * String) => Int {
    String -> Substring(1 -> From * 4 -> To) -> Prefix -> (
        * "Add:" => Int { Int -> Sum(String -> Length) }
        * Prefix => Int { Int }
    )
}

Unit => Program {
    10
        -> Routed("Add:xyz")
        -> Print
    10
        -> Routed("Nope")
        -> Print
}
