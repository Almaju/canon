Prefix = String

Routed = Int

Int * String => Routed {
    String -> Substring(1 -> From * 4 -> To) -> Prefix -> (
        * "Add:" => Routed { Int -> Sum(String -> Length) }
        * Prefix => Routed { Int }
    )
}

Unit => Program {
    10
        -> Routed("Add:xyz")
        -> Print
    10
        -> Routed("Nope")
        -> Print
}
