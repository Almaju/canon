Prefix = String

route = (Int * String) => Int {
    Prefix(String -> Substring(From(1) * To(4))) -> (
        * "Add:" => Int { Int -> Sum(String -> Length) }
        * Prefix => Int { Int }
    )
}

main = () => Unit {
    10
        .route("Add:xyz")
        -> Print
    10
        .route("Nope")
        -> Print
}
