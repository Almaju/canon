Prefix = String

route = (Int * String) => Int {
    String -> Substring(1 -> From * 4 -> To) -> Prefix -> (
        * "Add:" => Int { Int -> Sum(String -> Length) }
        * Prefix => Int { Int }
    )
}

Unit => Program {
    10
        .route("Add:xyz")
        -> Print
    10
        .route("Nope")
        -> Print
}
