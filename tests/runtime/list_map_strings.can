Unit => Program {
    List("alpha" * "beta")
        -> Mapped((String) => String { `{String}!` })
        -> Json
        -> Print
    List("xx" * "yyy" * "z") -> Mapped((String) => Int { String -> Length }) -> At(2) -> (
        * None => Unit { "none" -> Print }
        * Some<Int> => Unit { Int -> Print }
    )
}
