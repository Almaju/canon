main = () -> Unit {
    List("alpha", "beta")
        .map((String) -> String { String.concat("!") })
        .toJsonArray()
        .print()
    List("xx", "yyy", "z").map((String) -> Int { String.length() }).get(2).(
        * (None) -> Unit { "none".print() }
        * (Some<Int>) -> Unit { Int.print() }
    )
}
