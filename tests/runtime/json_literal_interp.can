label = (Int) => Json {
    {"answer":Int,"doubled":Int -> Product(2),"ok":True()}
}

Unit => Result<Program, MalformedJson> {
    42
        .label()
        -> Print
    {"label":"life"} -> Print
    [1,2,3] -> Print
    [1 -> Sum(0),2 -> Sum(0),3 -> Sum(0)] -> Print
    {"who":"team","members":["alice","bob","carol"]}
        -> Json?
        -> Print
    Unit() -> Ok
}
