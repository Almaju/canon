Code = Int

HttpError = Code * Reason

Lookup = Reason

Missing = String

Printed = Unit

Reason = String

Bool => Result<Lookup, Missing> {
    Bool -> (
        * False => Result<Lookup, Missing> { Missing("user.name") -> Err }
        * True => Result<Lookup, Missing> { Reason("ada") -> Ok }
    )
}

HttpError => Printed {
    Printed(`http {HttpError.Code -> String}: {HttpError.Reason}`)
}

Missing => Printed {
    Printed(`missing key: {Missing}`)
}

Unit => Program {
    Code(500)
        -> HttpError(Reason("boom"))
        -> Printed
    True() -> Lookup -> (
        * Err<Missing> => Unit { Missing -> Printed }
        * Ok<Reason> => Unit { Reason -> Printed }
    )
    False() -> Lookup -> (
        * Err<Missing> => Unit { Missing -> Printed }
        * Ok<Reason> => Unit { Reason -> Printed }
    )
}
