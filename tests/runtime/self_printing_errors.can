Code = Int

HttpError = Code * Reason

Lookup = Reason

Missing = String

Printed = Unit

Reason = String

Bool => Result<Lookup, Missing> {
    Bool -> (
        * False => Result<Lookup, Missing> { Missing("user.name") -> Err }
        * True => Result<Lookup, Missing> { Reason("ada") -> Ok }
    )
}

HttpError => Printed {
    "http "
        -> Joined(HttpError.Code -> String)
        -> Joined(": ")
        -> Joined(HttpError.Reason)
        -> Printed
}

Missing => Printed {
    "missing key: "
        -> Joined(Missing)
        -> Printed
}

Unit => Program {
    Code(500)
        -> HttpError(Reason("boom"))
        -> Printed
    True() -> Lookup -> (
        * Err<Missing> => Unit { Missing -> Printed }
        * Ok<Reason> => Unit { Reason -> Printed }
    )
    False() -> Lookup -> (
        * Err<Missing> => Unit { Missing -> Printed }
        * Ok<Reason> => Unit { Reason -> Printed }
    )
}
