Unit => Result<Program, MalformedJson> {
    "[1, 2,"
        -> Joined(" 3]")
        -> Json?
        -> Print
    "{\"a\":1,"
        -> Joined("\"b\":[true,false,null]}")
        -> Json?
        -> Print
    Json("\"a plain string\"")? -> Print
    Json("42")? -> Print
    Json("null")? -> Print
    Unit() -> Ok
}
