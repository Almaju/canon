Doc = String

Unit => Result<Program, MalformedJson> {
    Doc("[1, 2, 3]")
        -> Json?
        -> Print
    Doc("{\"a\":1,\"b\":[true,false,null]}")
        -> Json?
        -> Print
    Json("\"a plain string\"")? -> Print
    Json("42")? -> Print
    Json("null")? -> Print
    Unit() -> Ok
}
