Attr = String

Tag = String

Wrapped = String

Attr * String * Tag => Wrapped {
    "<"
        -> Joined(Tag)
        -> Joined(" ")
        -> Joined(Attr)
        -> Joined(">")
        -> Joined(String)
        -> Joined("</")
        -> Joined(Tag)
        -> Joined(">")
}

Unit => Program {
    Attr("class=\"x\"")
        -> Wrapped("inner" * Tag("div"))
        -> Print
}
