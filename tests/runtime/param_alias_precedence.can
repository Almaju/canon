Attr = String

Tag = String

wrap = (Attr * String * Tag) => String {
    "<"
        -> Joined(Tag)
        -> Joined(" ")
        -> Joined(Attr)
        -> Joined(">")
        -> Joined(String)
        -> Joined("</")
        -> Joined(Tag)
        -> Joined(">")
}

main = () => Unit {
    Attr("class=\"x\"")
        .wrap("inner", Tag("div"))
        -> Print
}
