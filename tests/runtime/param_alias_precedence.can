Attr = String

Tag = String

wrap = (Attr * String * Tag) => String {
    "<"
        -> Joined(Tag)
        -> Joined(" ")
        -> Joined(Attr)
        -> Joined(">")
        -> Joined(String)
        -> Joined("</")
        -> Joined(Tag)
        -> Joined(">")
}

Unit => Program {
    "class=\"x\""
        -> Attr
        .wrap("inner" * "div" -> Tag)
        -> Print
}
