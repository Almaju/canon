Attr = String

Tag = String

Wrapped = (Attr * String * Tag) => String {
    "<"
        -> Joined(Tag)
        -> Joined(" ")
        -> Joined(Attr)
        -> Joined(">")
        -> Joined(String)
        -> Joined("</")
        -> Joined(Tag)
        -> Joined(">")
}

Unit => Program {
    "class=\"x\""
        -> Attr
        -> Wrapped("inner" * "div" -> Tag)
        -> Print
}
