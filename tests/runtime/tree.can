Branch = Left * Right * Value

Described = String

Left = Tree

Right = Tree

Tree = Branch + Leaf

Value = Int

Tree => Described {
    Tree -> (
        * Branch => Described { "branch" }
        * Leaf => Described { "leaf" }
    )
}

Unit => Program {
    Leaf()
        -> Described
        -> Print
    Value(7)
        -> Branch(Leaf() -> Left * Leaf() -> Right)
        -> Described
        -> Print
}
