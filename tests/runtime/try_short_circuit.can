Classified = String

Described = String

Int => Result<Classified, String> {
    Int -> Eq(0) -> (
        * False => Result<Classified, String> { "nonzero" -> Ok }
        * True => Result<Classified, String> { "was zero" -> Err }
    )
}

Int => Result<Described, String> {
    Int
        -> Classified?
        -> Joined(" indeed")
        -> Ok
}

Unit => Program {
    3 -> Described -> (
        * Err<String> => Unit { String -> Print }
        * Ok<String> => Unit { String -> Print }
    )
    0 -> Described -> (
        * Err<String> => Unit { String -> Print }
        * Ok<String> => Unit { String -> Print }
    )
}
