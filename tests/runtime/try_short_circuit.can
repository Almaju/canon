Classified = String

Described = String

Int => Result<Classified, String> {
    Int -> Eq(0) -> (
        * False => Result<Classified, String> { Ok("nonzero") }
        * True => Result<Classified, String> { Err("was zero") }
    )
}

Int => Result<Described, String> {
    Ok(`{Int -> Classified?} indeed`)
}

Unit => Program {
    Described(3) -> (
        * Err<String> => Unit { String -> Print }
        * Ok<String> => Unit { String -> Print }
    )
    Described(0) -> (
        * Err<String> => Unit { String -> Print }
        * Ok<String> => Unit { String -> Print }
    )
}
