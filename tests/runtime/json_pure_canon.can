Shown = Unit

Result => Shown {
    Result -> (
        * Err<MalformedJson> => Shown { "FAIL" -> Print }
        * Ok<Json> => Shown { "OK" -> Print }
    )
}

Unit => Program {
    Json("true") -> Shown
    Json("false") -> Shown
    Json("null") -> Shown
    Json("42") -> Shown
    Json("-3.14e2") -> Shown
    Json("\"hello\"") -> Shown
    "[1, 2,"
        -> Joined(" 3]")
        -> Json
        -> Shown
    "["
        -> Joined("]")
        -> Json
        -> Shown
    "{"
        -> Joined("}")
        -> Json
        -> Shown
    "{\"a\": 1,"
        -> Joined(" \"b\": [true, false, null]}")
        -> Json
        -> Shown
    "{\"nested\": {\"deep\":"
        -> Joined(" [1, [2, [3]]]}}")
        -> Json
        -> Shown
    Json("  true  ") -> Shown
    Json("garbage") -> Shown
    Json("{bad}") -> Shown
    "[1, 2,"
        -> Joined("]")
        -> Json
        -> Shown
    Json("true junk") -> Shown
}
