Doc = String

Shown = Unit

Result => Shown {
    Result -> (
        * Err<MalformedJson> => Shown { "FAIL" -> Print }
        * Ok<Json> => Shown { "OK" -> Print }
    )
}

Unit => Program {
    Json("true") -> Shown
    Json("false") -> Shown
    Json("null") -> Shown
    Json("42") -> Shown
    Json("-3.14e2") -> Shown
    Json("\"hello\"") -> Shown
    Doc("[1, 2, 3]")
        -> Json
        -> Shown
    Doc("[]")
        -> Json
        -> Shown
    Doc("{}")
        -> Json
        -> Shown
    Doc("{\"a\": 1, \"b\": [true, false, null]}")
        -> Json
        -> Shown
    Doc("{\"nested\": {\"deep\": [1, [2, [3]]]}}")
        -> Json
        -> Shown
    Json("  true  ") -> Shown
    Json("garbage") -> Shown
    Json("{bad}") -> Shown
    Doc("[1, 2,]")
        -> Json
        -> Shown
    Json("true junk") -> Shown
}
