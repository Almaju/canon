show = (Result) => Unit {
    Result -> (
        * Err<MalformedJson> => Unit { "FAIL" -> Print }
        * Ok<Json> => Unit { "OK" -> Print }
    )
}

Unit => Program {
    "true"
        -> Json
        .show()
    "false"
        -> Json
        .show()
    "null"
        -> Json
        .show()
    "42"
        -> Json
        .show()
    "-3.14e2"
        -> Json
        .show()
    "\"hello\""
        -> Json
        .show()
    "[1, 2, 3]"
        -> Json
        .show()
    "[]"
        -> Json
        .show()
    "{}"
        -> Json
        .show()
    "{\"a\": 1, \"b\": [true, false, null]}"
        -> Json
        .show()
    "{\"nested\": {\"deep\": [1, [2, [3]]]}}"
        -> Json
        .show()
    "  true  "
        -> Json
        .show()
    "garbage"
        -> Json
        .show()
    "{bad}"
        -> Json
        .show()
    "[1, 2,]"
        -> Json
        .show()
    "true junk"
        -> Json
        .show()
}
