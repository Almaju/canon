Shown = Unit

Result => Shown {
    Result -> (
        * Err<MalformedJson> => Shown { "FAIL" -> Print }
        * Ok<Json> => Shown { "OK" -> Print }
    )
}

Unit => Program {
    "true"
        -> Json
        -> Shown
    "false"
        -> Json
        -> Shown
    "null"
        -> Json
        -> Shown
    "42"
        -> Json
        -> Shown
    "-3.14e2"
        -> Json
        -> Shown
    "\"hello\""
        -> Json
        -> Shown
    "[1, 2, 3]"
        -> Json
        -> Shown
    "[]"
        -> Json
        -> Shown
    "{}"
        -> Json
        -> Shown
    "{\"a\": 1, \"b\": [true, false, null]}"
        -> Json
        -> Shown
    "{\"nested\": {\"deep\": [1, [2, [3]]]}}"
        -> Json
        -> Shown
    "  true  "
        -> Json
        -> Shown
    "garbage"
        -> Json
        -> Shown
    "{bad}"
        -> Json
        -> Shown
    "[1, 2,]"
        -> Json
        -> Shown
    "true junk"
        -> Json
        -> Shown
}
