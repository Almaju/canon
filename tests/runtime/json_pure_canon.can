Shown = Unit

Result => Shown {
    Result -> (
        * Err<MalformedJson> => Shown { "FAIL" -> Print }
        * Ok<Json> => Shown { "OK" -> Print }
    )
}

Unit => Program {
    Json("true") -> Shown
    Json("false") -> Shown
    Json("null") -> Shown
    Json("42") -> Shown
    Json("-3.14e2") -> Shown
    Json("\"hello\"") -> Shown
    Json("[1, 2, 3]") -> Shown
    Json("[]") -> Shown
    Json("{}") -> Shown
    Json("{\"a\": 1, \"b\": [true, false, null]}") -> Shown
    Json("{\"nested\": {\"deep\": [1, [2, [3]]]}}") -> Shown
    Json("  true  ") -> Shown
    Json("garbage") -> Shown
    Json("{bad}") -> Shown
    Json("[1, 2,]") -> Shown
    Json("true junk") -> Shown
}
