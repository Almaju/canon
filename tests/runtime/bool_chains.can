main = () -> Unit {
    True().print()
    False().print()
    True()
        .And(False())
        .print()
    True()
        .And(True())
        .print()
    False()
        .Or(True())
        .print()
    True()
        .Not()
        .print()
    1
        .eq(1)
        .And(2.eq(2))
        .print()
    1
        .eq(2)
        .Or(1.eq(1))
        .Not()
        .print()
}
