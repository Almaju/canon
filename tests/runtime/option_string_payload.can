Picked = String

Int => Option<Picked> {
    Int -> Eq(0) -> (
        * False => Option<Picked> { Some("payload") }
        * True => Option<Picked> { None() }
    )
}

Unit => Program {
    Picked(1) -> (
        * None => Unit { "none" -> Print }
        * Some<String> => Unit { String -> Print }
    )
    Picked(0) -> (
        * None => Unit { "none" -> Print }
        * Some<String> => Unit { String -> Print }
    )
}
