main = () => Result<Unit, Unit> {
    Ok("model") -> (
        * Err<Unit> => Unit { "err" -> Print }
        * Ok<String> => Unit {
            "first: "
                -> Joined("literal")
                -> Print
            String -> Print
            "echo: "
                -> Joined(String)
                -> Joined(":")
                -> Joined(String)
                -> Print
        }
    )
    Ok(Unit())
}
