first = (Int) => Option<String> {
    Int -> Eq(0).(
        * False => Option<String> { Some("found") }
        * True => Option<String> { None() }
    )
}

second = (Int) => Option<String> {
    Some(Int -> First? -> Joined(" and used"))
}

main = () => Unit {
    5.second().(
        * None => Unit { "none" -> Print }
        * Some<String> => Unit { String -> Print }
    )
    0.second().(
        * None => Unit { "none" -> Print }
        * Some<String> => Unit { String -> Print }
    )
}
