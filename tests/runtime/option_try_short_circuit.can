First = String

Second = String

Int => Option<First> {
    Int -> Eq(0) -> (
        * False => Option<First> { "found" -> Some }
        * True => Option<First> { None() }
    )
}

Int => Option<Second> {
    Int
        -> First?
        -> Joined(" and used")
        -> Some
}

Unit => Program {
    5 -> Second -> (
        * None => Unit { "none" -> Print }
        * Some<String> => Unit { String -> Print }
    )
    0 -> Second -> (
        * None => Unit { "none" -> Print }
        * Some<String> => Unit { String -> Print }
    )
}
