DecodedShown = Unit

FieldShown = Unit

Sought = String

String => DecodedShown {
    String -> Json -> (
        * Err<MalformedJson> => DecodedShown { MalformedJson -> Print }
        * Ok<Json> => DecodedShown {
            Json -> Decoded -> (
                * Err<MalformedJson> => DecodedShown { MalformedJson -> Print }
                * Ok<Decoded> => DecodedShown { Decoded -> Print }
            )
        }
    )
}

Sought * String => FieldShown {
    String -> Json -> (
        * Err<MalformedJson> => FieldShown { MalformedJson -> Print }
        * Ok<Json> => FieldShown {
            Json -> Field(Sought) -> (
                * Err<MalformedJson> => FieldShown { MalformedJson -> Print }
                * Ok<Json> => FieldShown { Json -> Print }
            )
        }
    )
}

Unit => Program {
    Sought("b") -> FieldShown("{\"a\":1,\"b\":\"two\",\"c\":[1,2]}")
    Sought("c") -> FieldShown("{\"a\":1,\"b\":\"two\",\"c\":[1,{\"d\":4}]}")
    Sought("missing") -> FieldShown("{\"a\":1,\"b\":\"two\"}")
    Sought("a") -> FieldShown("[1,2]")
    DecodedShown("\"line\\nbreak\\ttab.\"")
    DecodedShown("\"esc \\\" quote and \\\\ slash\"")
    DecodedShown("\"caf\\u00e9 \\u2713 ok\"")
    DecodedShown("\"bad\\qesc\"")
    DecodedShown("42")
}
