ChatCompletionRequest = Model

Model = String

Json => Result<ChatCompletionRequest, MalformedJson> {
    Json
        -> Field("model")?
        -> Decoded?
        -> Model
        -> Ok
}

Unit => Result<Program, MalformedJson> {
    "{\"model\":\"gpt-4\"}"
        -> Json?
        -> ChatCompletionRequest?
        -> Print
    Unit() -> Ok
}
