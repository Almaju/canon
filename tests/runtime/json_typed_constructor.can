ChatCompletionRequest = Model

Model = String

ChatCompletionRequest = (Json) -> Result<ChatCompletionRequest, MalformedJson> {
    Json
        .field("model")?
        .asString()
}

main = () -> Result<Unit, MalformedJson> {
    Json("{\"model\":\"gpt-4\"}")?
        .ChatCompletionRequest()?
        .print()
    Ok(Unit())
}
