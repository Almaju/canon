Count = Int

Empty = Unit

Name = String

Ratio = Float

Shape = Count
  + Empty
  + Name
  + Ratio

MadeCount = () => Shape {
    42 -> Count
}

MadeEmpty = () => Shape {
    Empty()
}

MadeName = () => Shape {
    "alex" -> Name
}

MadeRatio = () => Shape {
    2.5 -> Ratio
}

Shown = (Shape) => Unit {
    Shape -> (
        * Count => Unit { Count -> Print }
        * Empty => Unit { "empty" -> Print }
        * Name => Unit { Name -> Print }
        * Ratio => Unit { Ratio -> Print }
    )
}

Unit => Program {
    MadeCount() -> Shown
    MadeEmpty() -> Shown
    MadeName() -> Shown
    MadeRatio() -> Shown
}
