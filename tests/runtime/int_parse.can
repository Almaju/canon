Unit => Program {
    Int("42") -> (
        * Err<MalformedInt> => Unit { "err" -> Print }
        * Ok<Int> => Unit { Int -> Print }
    )
    Int("-7") -> (
        * Err<MalformedInt> => Unit { "err" -> Print }
        * Ok<Int> => Unit { Int -> Print }
    )
    Int("123") -> (
        * Err<MalformedInt> => Unit { "err" -> Print }
        * Ok<Int> => Unit { Int -> Print }
    )
    Int("abc") -> (
        * Err<MalformedInt> => Unit { MalformedInt -> Print }
        * Ok<Int> => Unit { Int -> Print }
    )
    Int("") -> (
        * Err<MalformedInt> => Unit { MalformedInt -> Print }
        * Ok<Int> => Unit { Int -> Print }
    )
    Int("-") -> (
        * Err<MalformedInt> => Unit { MalformedInt -> Print }
        * Ok<Int> => Unit { Int -> Print }
    )
}
