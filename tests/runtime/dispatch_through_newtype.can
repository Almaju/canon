Content = String

MessageContent = Option<Content>

Dispatched = (MessageContent) => Unit {
    MessageContent -> (
        * None => Unit { "absent" -> Print }
        * Some<Content> => Unit { "present" -> Print }
    )
}

Unit => Program {
    "hi"
        -> Some
        -> MessageContent
        -> Dispatched
    None()
        -> MessageContent
        -> Dispatched
}
