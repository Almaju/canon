Content = String

Dispatched = Unit

MessageContent = Option<Content>

MessageContent => Dispatched {
    MessageContent -> (
        * None => Dispatched { "absent" -> Print }
        * Some<Content> => Dispatched { "present" -> Print }
    )
}

Unit => Program {
    "hi"
        -> Some
        -> MessageContent
        -> Dispatched
    None()
        -> MessageContent
        -> Dispatched
}
