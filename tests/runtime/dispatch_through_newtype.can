Content = String

MessageContent = Option<Content>

dispatch = (MessageContent) => Unit {
    MessageContent -> (
        * None => Unit { "absent" -> Print }
        * Some<Content> => Unit { "present" -> Print }
    )
}

main = () => Unit {
    "hi"
        -> Some
        -> MessageContent
        .dispatch()
    None()
        -> MessageContent
        .dispatch()
}
