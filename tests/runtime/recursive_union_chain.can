Chain = Link + Stop

Label = String

LastLabel = String

Length = Int

Link = Label * Next

Next = Chain

Chain => LastLabel {
    Chain -> (
        * Link => LastLabel {
            Link.Next -> Length -> Eq(0) -> (
                * False => LastLabel { Link.Next -> LastLabel }
                * True => LastLabel { Link.Label }
            )
        }
        * Stop => LastLabel { "" }
    )
}

Chain => Length {
    Chain -> (
        * Link => Length { Link.Next -> Length -> Sum(1) }
        * Stop => Length { 0 }
    )
}

Unit => Program {
    "a"
        -> Link("b" -> Link("c" -> Link(Stop())))
        -> Length
        -> Print
    "a"
        -> Link("b" -> Link(Stop()))
        -> LastLabel
        -> Print
}
