Chain = Link + Stop

Label = String

Link = Label * Next

Next = Chain

LastLabel = (Chain) => String {
    Chain -> (
        * Link => String {
            Link.Next -> Length -> Eq(0) -> (
                * False => String { Link.Next -> LastLabel }
                * True => String { Link.Label }
            )
        }
        * Stop => String { "" }
    )
}

Length = (Chain) => Int {
    Chain -> (
        * Link => Int { Link.Next -> Length -> Sum(1) }
        * Stop => Int { 0 }
    )
}

Unit => Program {
    "a"
        -> Link("b" -> Link("c" -> Link(Stop())))
        -> Length
        -> Print
    "a"
        -> Link("b" -> Link(Stop()))
        -> LastLabel
        -> Print
}
