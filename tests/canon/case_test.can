LowercasedFoldsLetters = TestResult

Unit => LowercasedFoldsLetters {
    Lowercased("GoodBye")
        -> Eq("goodbye")
        -> TestResult
}

LowercasedKeepsBytesAboveUppercaseRange = TestResult

Unit => LowercasedKeepsBytesAboveUppercaseRange {
    Lowercased("[\\]^_`")
        -> Eq("[\\]^_`")
        -> TestResult
}

LowercasedKeepsNonLetters = TestResult

Unit => LowercasedKeepsNonLetters {
    Lowercased("MiXeD 123 !?")
        -> Eq("mixed 123 !?")
        -> TestResult
}

UppercasedFoldsLetters = TestResult

Unit => UppercasedFoldsLetters {
    Uppercased("Hello, World")
        -> Eq("HELLO, WORLD")
        -> TestResult
}

UppercasedKeepsBytesAboveLowercaseRange = TestResult

Unit => UppercasedKeepsBytesAboveLowercaseRange {
    Uppercased("abc{|}~")
        -> Eq("ABC{|}~")
        -> TestResult
}

UppercasedKeepsNonLetters = TestResult

Unit => UppercasedKeepsNonLetters {
    Uppercased("MiXeD 123 !?")
        -> Eq("MIXED 123 !?")
        -> TestResult
}
