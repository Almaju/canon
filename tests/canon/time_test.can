testNowFromLeapDay = () => TestResult {
    951782400
        -> Unix
        -> Now
        -> Eq("2000-02-29T00:00:00Z")
        -> TestResult("Unix timestamp decodes a leap-year Feb 29")
}

testNowFromUnixEpoch = () => TestResult {
    0
        -> Unix
        -> Now
        -> Eq("1970-01-01T00:00:00Z")
        -> TestResult("Unix timestamp 0 decodes to the epoch")
}

testNowFromUnixWithTimeOfDay = () => TestResult {
    1704070861
        -> Unix
        -> Now
        -> Eq("2024-01-01T01:01:01Z")
        -> TestResult("Unix timestamp decodes date and time-of-day together")
}

testNowLength = () => TestResult {
    Now()
        -> Length
        -> Eq(20)
        -> TestResult("RFC3339 timestamp is 20 chars")
}

testNowSeparator = () => TestResult {
    Now()
        -> ByteAt(11)
        -> Eq(84)
        -> TestResult("T separates date and time")
}

testPaddedOverWidth = () => TestResult {
    123
        -> Padded(2)
        -> Eq("123")
        -> TestResult("Padded leaves a value wider than the width unchanged")
}

testPaddedZeroFills = () => TestResult {
    5
        -> Padded(4)
        -> Eq("0005")
        -> TestResult("Padded left-fills with zeros to the given width")
}

testUnixAfter2001 = () => TestResult {
    Unix()
        -> Ge(1000000000)
        -> TestResult("wall clock reads after 2001-09-09")
}
