ClockFamiliesCoexist = TestResult

Unit => ClockFamiliesCoexist {
    Mark()
        -> Ge(0)
        -> And(Unix() -> Ge(0))
        -> TestResult
}

DateDecodesLeapDay = TestResult

LeapDayDate = Bool

Unit => DateDecodesLeapDay {
    Unix(951782400)
        -> Date
        -> LeapDayDate
        -> TestResult
}

Civil => LeapDayDate {
    Civil.Day
        -> Eq(29)
        -> And(Civil.Month -> Eq(2))
        -> And(Civil.Year -> Eq(2000))
}

NowDecodesEpoch = TestResult

Unit => NowDecodesEpoch {
    Unix(0)
        -> Now
        -> Eq("1970-01-01T00:00:00Z")
        -> TestResult
}

NowDecodesLeapDay = TestResult

Unit => NowDecodesLeapDay {
    Unix(951782400)
        -> Now
        -> Eq("2000-02-29T00:00:00Z")
        -> TestResult
}

NowDecodesMidYearDate = TestResult

Unit => NowDecodesMidYearDate {
    Unix(1720096496)
        -> Now
        -> Eq("2024-07-04T12:34:56Z")
        -> TestResult
}

NowDecodesTimeOfDay = TestResult

Unit => NowDecodesTimeOfDay {
    Unix(1704070861)
        -> Now
        -> Eq("2024-01-01T01:01:01Z")
        -> TestResult
}

NowIsRfc3339Length = TestResult

Unit => NowIsRfc3339Length {
    Now()
        -> Length
        -> Eq(20)
        -> TestResult
}

NowSeparatesDateAndTime = TestResult

Unit => NowSeparatesDateAndTime {
    Now()
        -> ByteAt(11)
        -> Eq(84)
        -> TestResult
}

PaddedLeavesWiderValue = TestResult

Unit => PaddedLeavesWiderValue {
    123
        -> Padded(2)
        -> Eq("123")
        -> TestResult
}

PaddedZeroFills = TestResult

Unit => PaddedZeroFills {
    5
        -> Padded(4)
        -> Eq("0005")
        -> TestResult
}

TimeOfDayParts = Bool

Unix => TimeOfDayParts {
    Unix
        -> Hour
        -> Eq(12)
        -> And(Unix -> Minute -> Eq(34))
        -> And(Unix -> Second -> Eq(56))
}

UnixDecodesTimeOfDay = TestResult

Unit => UnixDecodesTimeOfDay {
    Unix(1720096496)
        -> TimeOfDayParts
        -> TestResult
}

UnixReadsAfter2001 = TestResult

Unit => UnixReadsAfter2001 {
    Unix()
        -> Ge(1000000000)
        -> TestResult
}

WeekdayOfEpochIsThursday = TestResult

Unit => WeekdayOfEpochIsThursday {
    Unix(0)
        -> Weekday
        -> Eq(4)
        -> TestResult
}

WeekdayOfLeapDayIsTuesday = TestResult

Unit => WeekdayOfLeapDayIsTuesday {
    Unix(951782400)
        -> Weekday
        -> Eq(2)
        -> TestResult
}
