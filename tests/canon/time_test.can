testNowLength = () => TestResult {
    Now()
        -> Length
        -> Eq(20)
        -> TestResult("RFC3339 timestamp is 20 chars")
}

testNowSeparator = () => TestResult {
    Now()
        -> ByteAt(11)
        -> Eq(84)
        -> TestResult("T separates date and time")
}

testPaddedOverWidth = () => TestResult {
    123
        -> Padded(2)
        -> Eq("123")
        -> TestResult("Padded leaves a value wider than the width unchanged")
}

testPaddedZeroFills = () => TestResult {
    5
        -> Padded(4)
        -> Eq("0005")
        -> TestResult("Padded left-fills with zeros to the given width")
}

testUnixAfter2001 = () => TestResult {
    Unix()
        -> Ge(1000000000)
        -> TestResult("wall clock reads after 2001-09-09")
}
