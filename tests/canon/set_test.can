SetContainsFindsAfterRecursingPastEntries = TestResult

Unit => SetContainsFindsAfterRecursingPastEntries {
    Set()
        -> Inserted("a")
        -> Inserted("b")
        -> Inserted("c")
        -> Contains("c")
        -> TestResult
}

SetContainsFindsInserted = TestResult

Unit => SetContainsFindsInserted {
    Set()
        -> Inserted("x")
        -> Contains("x")
        -> TestResult
}

SetContainsRejectsAbsent = TestResult

Unit => SetContainsRejectsAbsent {
    Set()
        -> Inserted("x")
        -> Contains("y")
        -> Not
        -> TestResult
}

SetContainsRejectsAfterRecursingThroughEntries = TestResult

Unit => SetContainsRejectsAfterRecursingThroughEntries {
    Set()
        -> Inserted("a")
        -> Inserted("b")
        -> Inserted("c")
        -> Contains("d")
        -> Not
        -> TestResult
}

SetDedupesInserts = TestResult

Unit => SetDedupesInserts {
    Set()
        -> Inserted("b")
        -> Inserted("a")
        -> Inserted("b")
        -> Length
        -> Eq(2)
        -> TestResult
}

SetListSorted = TestResult

Unit => SetListSorted {
    Set()
        -> Inserted("b")
        -> Inserted("c")
        -> Inserted("a")
        -> List
        -> Json
        -> Eq("[a,b,c]")
        -> TestResult
}

SetRemovedAbsentIsNoOp = TestResult

Unit => SetRemovedAbsentIsNoOp {
    Set()
        -> Inserted("a")
        -> Removed("missing")
        -> Length
        -> Eq(1)
        -> TestResult
}

SetRemovedDropsValue = TestResult

Unit => SetRemovedDropsValue {
    Set()
        -> Inserted("a")
        -> Inserted("b")
        -> Removed("a")
        -> List
        -> Json
        -> Eq("[b]")
        -> TestResult
}

SetRemovedRecursesPastNonMatchingItem = TestResult

