SetContainsFindsInserted = () => TestResult {
    Set()
        -> Inserted("x")
        -> Contains("x")
        -> TestResult
}

SetContainsRejectsAbsent = () => TestResult {
    Set()
        -> Inserted("x")
        -> Contains("y")
        -> Not
        -> TestResult
}

SetDedupesInserts = () => TestResult {
    Set()
        -> Inserted("b")
        -> Inserted("a")
        -> Inserted("b")
        -> Length
        -> Eq(2)
        -> TestResult
}

SetListSorted = () => TestResult {
    Set()
        -> Inserted("b")
        -> Inserted("c")
        -> Inserted("a")
        -> List
        -> Json
        -> Eq("[a,b,c]")
        -> TestResult
}

SetRemovedAbsentIsNoOp = () => TestResult {
    Set()
        -> Inserted("a")
        -> Removed("missing")
        -> Length
        -> Eq(1)
        -> TestResult
}

SetRemovedDropsValue = () => TestResult {
    Set()
        -> Inserted("a")
        -> Inserted("b")
        -> Removed("a")
        -> List
        -> Json
        -> Eq("[b]")
        -> TestResult
}
