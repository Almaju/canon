SetContainsFindsAdded = TestResult

Unit => SetContainsFindsAdded {
    Set()
        -> Added("x")
        -> Contains("x")
        -> TestResult
}

SetContainsFindsAfterRecursingPastEntries = TestResult

Unit => SetContainsFindsAfterRecursingPastEntries {
    Set()
        -> Added("a")
        -> Added("b")
        -> Added("c")
        -> Contains("c")
        -> TestResult
}

SetContainsRejectsAbsent = TestResult

Unit => SetContainsRejectsAbsent {
    Set()
        -> Added("x")
        -> Contains("y")
        -> Not
        -> TestResult
}

SetContainsRejectsAfterRecursingThroughEntries = TestResult

Unit => SetContainsRejectsAfterRecursingThroughEntries {
    Set()
        -> Added("a")
        -> Added("b")
        -> Added("c")
        -> Contains("d")
        -> Not
        -> TestResult
}

SetDedupesInserts = TestResult

Unit => SetDedupesInserts {
    Set()
        -> Added("b")
        -> Added("a")
        -> Added("b")
        -> Length
        -> Eq(2)
        -> TestResult
}

SetDroppedAbsentIsNoOp = TestResult

Unit => SetDroppedAbsentIsNoOp {
    Set()
        -> Added("a")
        -> Dropped("missing")
        -> Length
        -> Eq(1)
        -> TestResult
}

SetDroppedDropsValue = TestResult

Unit => SetDroppedDropsValue {
    Set()
        -> Added("a")
        -> Added("b")
        -> Dropped("a")
        -> List
        -> Json
        -> Eq("[b]")
        -> TestResult
}

SetDroppedRecursesPastNonMatchingItem = TestResult

Unit => SetDroppedRecursesPastNonMatchingItem {
    Set()
        -> Added("a")
        -> Added("b")
        -> Dropped("b")
        -> List
        -> Json
        -> Eq("[a]")
        -> TestResult
}

SetListSorted = TestResult

Unit => SetListSorted {
    Set()
        -> Added("b")
        -> Added("c")
        -> Added("a")
        -> List
        -> Json
        -> Eq("[a,b,c]")
        -> TestResult
}
