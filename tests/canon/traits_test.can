Greeting = String

Name = String

Show = () => String

Show = (Greeting) => String {
    "HELLO!"
}

Show = (Name) => String {
    "Alice"
}

ShowResolvesByInputType = TestResult

Unit => ShowResolvesByInputType {
    "hi"
        -> Greeting
        -> Show
    "Alice"
        -> Name
        -> Show
    Pass()
}
