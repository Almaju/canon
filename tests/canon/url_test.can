UrlAcceptsHttp = TestResult

Unit => UrlAcceptsHttp {
    Url("http://example.com") -> (
        * Err<InvalidUrl> => TestResult { Fail("http URL should validate") }
        * Ok<Url> => TestResult { Url -> Eq("http://example.com") -> TestResult }
    )
}

UrlAcceptsHttps = TestResult

Unit => UrlAcceptsHttps {
    Url("https://a.test/x") -> (
        * Err<InvalidUrl> => TestResult { Fail("https URL should validate") }
        * Ok<Url> => TestResult { Url -> Eq("https://a.test/x") -> TestResult }
    )
}

UrlRejectsDoubleSlashHost = TestResult

Unit => UrlRejectsDoubleSlashHost {
    Url("http:///path") -> (
        * Err<InvalidUrl> => TestResult { Pass() }
        * Ok<Url> => TestResult { Fail("\"http:///path\" should not validate") }
    )
}

UrlRejectsEmptyHost = TestResult

Unit => UrlRejectsEmptyHost {
    Url("http://") -> (
        * Err<InvalidUrl> => TestResult { Pass() }
        * Ok<Url> => TestResult { Fail("\"http://\" should not validate") }
    )
}

UrlRejectsEmptyHostBeforeSlash = TestResult

Unit => UrlRejectsEmptyHostBeforeSlash {
    Url("http:///path") -> (
        * Err<InvalidUrl> => TestResult { Pass() }
        * Ok<Url> => TestResult { Fail("\"http:///path\" should not validate") }
    )
}

