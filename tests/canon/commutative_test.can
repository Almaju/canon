Greeted = Greeting

Greeting = String

Name = String

Greeting * Name => Greeted {
    Greeting
}

ProductCallableBothWays = TestResult

Unit => ProductCallableBothWays {
    Greeting("hello") -> Greeted(Name("world"))
    Name("world") -> Greeted(Greeting("hello"))
    Pass()
}

ProductCanonicalDirection = TestResult

Unit => ProductCanonicalDirection {
    Greeting("hello") -> Greeted(Name("world"))
    Pass()
}

ProductNonCanonicalDirection = TestResult

Unit => ProductNonCanonicalDirection {
    Name("world") -> Greeted(Greeting("hello"))
    Pass()
}
