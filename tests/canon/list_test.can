ListConstructionCountsElements = () => TestResult {
    List(1 * 2 * 3)
        -> Length
        -> Eq(3)
        -> TestResult
}

MappedPreservesLength = () => TestResult {
    List(1 * 2 * 3)
        -> Mapped((Int) => Int { Int -> Product(2) })
        -> Length
        -> Eq(3)
        -> TestResult
}
