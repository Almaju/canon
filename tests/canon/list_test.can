testListConstruction = () => TestResult {
    List(1 * 2 * 3)
        -> Length
        -> Eq(3)
        -> TestResult("List(1 *2 *3) should have length 3")
}

testListMapPreservesLength = () => TestResult {
    List(1 * 2 * 3)
        -> Mapped((Int) => Int { Int -> Product(2) })
        -> Length
        -> Eq(3)
        -> TestResult("map should preserve length")
}
