testAddIdentity = () => TestResult {
    5
        -> Sum(0)
        -> Eq(5)
        -> TestResult("5 + 0 should be 5")
}

testAddPositive = () => TestResult {
    1
        -> Sum(2)
        -> Eq(3)
        -> TestResult("1 + 2 should be 3")
}

testDiv = () => TestResult {
    20
        -> Quotient(4)
        -> Eq(5)
        -> TestResult("20 / 4 should be 5")
}

testEqReflexive = () => TestResult {
    5
        -> Eq(5)
        -> TestResult("5 should equal itself")
}

testMaximum = () => TestResult {
    3
        -> Maximum(7)
        -> Eq(7)
        -> TestResult("max(3, 7) should be 7")
}

testMinimum = () => TestResult {
    3
        -> Minimum(7)
        -> Eq(3)
        -> TestResult("min(3, 7) should be 3")
}

testMinimumNegative = () => TestResult {
    0
        -> Difference(5)
        -> Minimum(2)
        -> Eq(0 -> Difference(5))
        -> TestResult("min(-5, 2) should be -5")
}

testMul = () => TestResult {
    3
        -> Product(4)
        -> Eq(12)
        -> TestResult("3 * 4 should be 12")
}

testSub = () => TestResult {
    10
        -> Difference(3)
        -> Eq(7)
        -> TestResult("10 - 3 should be 7")
}
