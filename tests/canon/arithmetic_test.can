DifferenceSubtracts = () => TestResult {
    10
        -> Difference(3)
        -> Eq(7)
        -> TestResult
}

EqIsReflexive = () => TestResult {
    5
        -> Eq(5)
        -> TestResult
}

HexLiteralArithmetic = () => TestResult {
    0xFF
        -> Sum(1)
        -> Eq(256)
        -> TestResult
}

MaximumPicksLarger = () => TestResult {
    3
        -> Maximum(7)
        -> Eq(7)
        -> TestResult
}

MaximumWhenFirstIsLarger = () => TestResult {
    7
        -> Maximum(3)
        -> Eq(7)
        -> TestResult
}

MinimumHandlesNegatives = () => TestResult {
    0
        -> Difference(5)
        -> Minimum(2)
        -> Eq(0 -> Difference(5))
        -> TestResult
}

MinimumPicksSmaller = () => TestResult {
    3
        -> Minimum(7)
        -> Eq(3)
        -> TestResult
}

MinimumWhenFirstIsLarger = () => TestResult {
    7
        -> Minimum(3)
        -> Eq(3)
        -> TestResult
}

ProductMultiplies = () => TestResult {
    3
        -> Product(4)
        -> Eq(12)
        -> TestResult
}

QuotientDivides = () => TestResult {
    20
        -> Quotient(4)
        -> Eq(5)
        -> TestResult
}

SumAddsOperands = () => TestResult {
    1
        -> Sum(2)
        -> Eq(3)
        -> TestResult
}

SumWithZeroIsIdentity = () => TestResult {
    5
        -> Sum(0)
        -> Eq(5)
        -> TestResult
}
