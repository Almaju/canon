MarkdownEscapesInline = TestResult

Unit => MarkdownEscapesInline {
    "a < b"
        -> Markdown
        -> Html
        -> Eq("<p>a &lt; b</p>")
        -> TestResult
}

MarkdownRendersBlockquote = TestResult

Unit => MarkdownRendersBlockquote {
    "> quoted text"
        -> Markdown
        -> Html
        -> Eq("<blockquote>quoted text</blockquote>")
        -> TestResult
}

MarkdownRendersBold = TestResult

Unit => MarkdownRendersBold {
    "a **bold** word"
        -> Markdown
        -> Html
        -> Eq("<p>a <strong>bold</strong> word</p>")
        -> TestResult
}

MarkdownRendersFencedCode = TestResult

Unit => MarkdownRendersFencedCode {
    "```\ncode line\n```"
        -> Markdown
        -> Html
        -> Eq("<pre data-info=\"\"><code>code line\n</code></pre>")
        -> TestResult
}

MarkdownRendersH2 = TestResult

Unit => MarkdownRendersH2 {
    "## Hello"
        -> Markdown
        -> Html
        -> Eq("<h2>Hello</h2>")
        -> TestResult
}

MarkdownRendersH3 = TestResult

Unit => MarkdownRendersH3 {
    "### Hello"
        -> Markdown
        -> Html
        -> Eq("<h3>Hello</h3>")
        -> TestResult
}

MarkdownRendersHeading = TestResult

Unit => MarkdownRendersHeading {
    "# Hello"
        -> Markdown
        -> Html
        -> Eq("<h1>Hello</h1>")
        -> TestResult
}

MarkdownRendersInlineCode = TestResult

Unit => MarkdownRendersInlineCode {
    "an `inline` code"
        -> Markdown
        -> Html
        -> Eq("<p>an <code>inline</code> code</p>")
        -> TestResult
}

MarkdownRendersItalic = TestResult

Unit => MarkdownRendersItalic {
    "an *italic* word"
        -> Markdown
        -> Html
        -> Eq("<p>an <em>italic</em> word</p>")
        -> TestResult
}

MarkdownRendersLink = TestResult

Unit => MarkdownRendersLink {
    "see [Canon](https://example.com) here"
        -> Markdown
        -> Html
        -> Eq("<p>see <a href=\"https://example.com\">Canon</a> here</p>")
        -> TestResult
}

MarkdownRendersNestedBoldInItalic = TestResult

Unit => MarkdownRendersNestedBoldInItalic {
    "*a **b** c*"
        -> Markdown
        -> Html
        -> Eq("<p><em>a <strong>b</strong> c</em></p>")
        -> TestResult
}

MarkdownRendersNestedList = TestResult

Unit => MarkdownRendersNestedList {
    "- item one\n  - sub item\n- item two"
        -> Markdown
        -> Html
        -> Eq("<ul><li>item one<ul><li>sub item</li></ul></li><li>item two</li></ul>")
        -> TestResult
}

MarkdownRendersOrderedList = TestResult

Unit => MarkdownRendersOrderedList {
    "1. first\n2. second"
        -> Markdown
        -> Html
        -> Eq("<ol><li>first</li><li>second</li></ol>")
        -> TestResult
}

MarkdownRendersTable = TestResult

Unit => MarkdownRendersTable {
    "| a | b |\n| --- | --- |\n| 1 | 2 |"
        -> Markdown
        -> Html
        -> Eq("<table><thead><tr><th> a </th><th> b </th></tr></thead><tbody><tr><td> 1 </td><td> 2 </td></tr></tbody></table>")
        -> TestResult
}

MarkdownWrapsParagraph = TestResult

Unit => MarkdownWrapsParagraph {
    "plain text"
        -> Markdown
        -> Html
        -> Eq("<p>plain text</p>")
        -> TestResult
}
