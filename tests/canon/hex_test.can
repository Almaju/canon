HexDecodesLowercase = TestResult

Unit => HexDecodesLowercase {
    Hex("666f6f626172") -> HexDecoded -> (
        * Err<MalformedHex> => HexDecodesLowercase { MalformedHex -> Fail }
        * Ok<HexDecoded> => HexDecodesLowercase { HexDecoded -> Eq("foobar") -> TestResult }
    )
}

HexDecodesUppercase = TestResult

Unit => HexDecodesUppercase {
    Hex("6A6B") -> HexDecoded -> (
        * Err<MalformedHex> => HexDecodesUppercase { MalformedHex -> Fail }
        * Ok<HexDecoded> => HexDecodesUppercase { HexDecoded -> Eq("jk") -> TestResult }
    )
}

HexEncodesBytes = TestResult

Unit => HexEncodesBytes {
    HexEncoded("foobar")
        -> Eq("666f6f626172")
        -> TestResult
}

HexEncodesEmpty = TestResult

Unit => HexEncodesEmpty {
    HexEncoded("")
        -> Eq("")
        -> TestResult
}

HexRejectsInvalidDigit = TestResult

Unit => HexRejectsInvalidDigit {
    Hex("6g") -> HexDecoded -> (
        * Err<MalformedHex> => HexRejectsInvalidDigit { Pass() }
        * Ok<HexDecoded> => HexRejectsInvalidDigit { Fail("accepted invalid digit") }
    )
}

HexRejectsOddLength = TestResult

Unit => HexRejectsOddLength {
    Hex("abc") -> HexDecoded -> (
        * Err<MalformedHex> => HexRejectsOddLength { Pass() }
        * Ok<HexDecoded> => HexRejectsOddLength { Fail("accepted odd length") }
    )
}

HexRoundTripsText = TestResult

Unit => HexRoundTripsText {
    HexEncoded("Canon!") -> HexDecoded -> (
        * Err<MalformedHex> => HexRoundTripsText { MalformedHex -> Fail }
        * Ok<HexDecoded> => HexRoundTripsText { HexDecoded -> Eq("Canon!") -> TestResult }
    )
}
