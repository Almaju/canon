DecodeRejectsBadEscape = TestResult

DecodeRejectsMalformedUnicodeEscape = TestResult

Unit => DecodeRejectsBadEscape {
    Json("\"\\q\"")? -> Decoded -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Decoded> => TestResult { Fail("unknown escape should be rejected") }
    )
}

DecodeUnescapesAllControlEscapes = TestResult

Unit => DecodeRejectsMalformedUnicodeEscape {
    Json("\"\\u00zz\"")? -> Decoded -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Decoded> => TestResult { Fail("non-hex \\u escape should be rejected") }
    )
}

DecodeUnescapesQuote = TestResult

Unit => DecodeUnescapesAllControlEscapes {
    Json("\"\\\\ \\/ \\b \\f \\n \\r \\t\"")?
        -> Decoded?
        -> Eq("\\ / \u0008 \u000C \n \r \t")
        -> TestResult
}

DecodeUnescapesUnicodeEscape = TestResult

Unit => DecodeUnescapesQuote {
    Json("\"esc \\\" quote\"")?
        -> Decoded?
        -> Eq("esc \" quote")
        -> TestResult
}

DecodeUnescapesUppercaseHexUnicode = TestResult

Unit => DecodeUnescapesUnicodeEscape {
    Json("\"\\u0041\\u00e9\\u20ac\"")?
        -> Decoded?
        -> Eq("Aé€")
        -> TestResult
}

DecodeUnwrapsString = TestResult

Unit => DecodeUnescapesUppercaseHexUnicode {
    Json("\"\\u00FF\"")?
        -> Decoded?
        -> Eq("ÿ")
        -> TestResult
}

Doc = String

Unit => DecodeUnwrapsString {
    Json("\"gpt-4\"")?
        -> Decoded?
        -> Eq("gpt-4")
        -> TestResult
}

EncodedFalse = TestResult

Unit => EncodedFalse {
    False()
        -> Encoded
        -> Eq("false")
        -> TestResult
}

EncodedFloat = TestResult

Unit => EncodedFloat {
    Encoded(1.5)
        -> Eq("1.5")
        -> TestResult
}

EncodedInt = TestResult

Unit => EncodedInt {
    Encoded(42)
        -> Eq("42")
        -> TestResult
}

EncodedStringEscapes = TestResult

Unit => EncodedStringEscapes {
    Encoded("a\"b\\c")
        -> Eq("\"a\\\"b\\\\c\"")
        -> TestResult
}

EncodedStringPlain = TestResult

Unit => EncodedStringPlain {
    Encoded("hi")
        -> Eq("\"hi\"")
        -> TestResult
}

EncodedTrue = TestResult

Unit => EncodedTrue {
    True()
        -> Encoded
        -> Eq("true")
        -> TestResult
}

FieldExtractsMember = TestResult

Unit => FieldExtractsMember {
    Doc("{\"model\":\"gpt-4\",\"stream\":true}")
        -> Json?
        -> Field("model")?
        -> Decoded?
        -> Eq("gpt-4")
        -> TestResult
}

FieldRejectsMissingKeyEmptyObject = TestResult

Unit => FieldRejectsMissingKeyEmptyObject {
    Doc("{}") -> Json? -> Field("missing") -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Json> => TestResult { Fail("\"missing\" should not resolve in {}") }
    )
}

FieldRejectsMissingKeyNoMatch = TestResult

Unit => FieldRejectsMissingKeyNoMatch {
    Doc("{\"model\":\"gpt-4\"}") -> Json? -> Field("missing") -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Json> => TestResult { Fail("\"missing\" should not resolve") }
    )
}

InvalidJsonRejected = TestResult

Unit => InvalidJsonRejected {
    Json("{oops") -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Json> => TestResult { Fail("\"{oops\" should not validate") }
    )
}

JsonAcceptsArray = TestResult

Unit => JsonAcceptsArray {
    Doc("[1,2,3]") -> Json -> (
        * Err<MalformedJson> => TestResult { Fail("\"[1,2,3]\" should validate as JSON") }
        * Ok<Json> => TestResult { Pass() }
    )
}

JsonAcceptsNull = TestResult

Unit => JsonAcceptsNull {
    Json("null") -> (
        * Err<MalformedJson> => TestResult { Fail("\"null\" should validate as JSON") }
        * Ok<Json> => TestResult { Pass() }
    )
}

JsonAcceptsNumber = TestResult

Unit => JsonAcceptsNumber {
    Json("-1.5e10") -> (
        * Err<MalformedJson> => TestResult { Fail("\"-1.5e10\" should validate as JSON") }
        * Ok<Json> => TestResult { Pass() }
    )
}

JsonRejectsMalformedNumber = TestResult

Unit => JsonRejectsMalformedNumber {
    Json("1.") -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Json> => TestResult { Fail("\"1.\" should not validate (missing fractional digits)") }
    )
}
