DecodeRejectsBadEscape = () => TestResult {
    "\"\\q\"" -> Json? -> Decoded -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Decoded> => TestResult { "unknown escape should be rejected" -> Fail }
    )
}

DecodeRejectsMalformedUnicodeEscape = () => TestResult {
    "\"\\u00zz\"" -> Json? -> Decoded -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Decoded> => TestResult { "non-hex \\u escape should be rejected" -> Fail }
    )
}

DecodeUnescapesAllControlEscapes = () => TestResult {
    "\"\\\\ \\/ \\b \\f \\n \\r \\t\""
        -> Json?
        -> Decoded?
        -> Eq("\\ / \u0008 \u000C \n \r \t")
        -> TestResult
}

DecodeUnescapesQuote = () => TestResult {
    "\"esc \\\" quote\""
        -> Json?
        -> Decoded?
        -> Eq("esc \" quote")
        -> TestResult
}

DecodeUnescapesUnicodeEscape = () => TestResult {
    "\"\\u0041\\u00e9\\u20ac\""
        -> Json?
        -> Decoded?
        -> Eq("Aé€")
        -> TestResult
}

DecodeUnescapesUppercaseHexUnicode = () => TestResult {
    "\"\\u00FF\""
        -> Json?
        -> Decoded?
        -> Eq("ÿ")
        -> TestResult
}

DecodeUnwrapsString = () => TestResult {
    "\"gpt-4\""
        -> Json?
        -> Decoded?
        -> Eq("gpt-4")
        -> TestResult
}

FieldExtractsMember = () => TestResult {
    "{\"model\":\"gpt-4\",\"stream\":true}"
        -> Json?
        -> Field("model")?
        -> Decoded?
        -> Eq("gpt-4")
        -> TestResult
}

FieldRejectsMissingKeyEmptyObject = () => TestResult {
    "{}" -> Json? -> Field("missing") -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Json> => TestResult { "\"missing\" should not resolve in {}" -> Fail }
    )
}

FieldRejectsMissingKeyNoMatch = () => TestResult {
    "{\"model\":\"gpt-4\"}" -> Json? -> Field("missing") -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Json> => TestResult { "\"missing\" should not resolve" -> Fail }
    )
}

InvalidJsonRejected = () => TestResult {
    "{oops" -> Json -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Json> => TestResult { "\"{oops\" should not validate" -> Fail }
    )
}

JsonAcceptsArray = () => TestResult {
    "[1,2,3]" -> Json -> (
        * Err<MalformedJson> => TestResult { "\"[1,2,3]\" should validate as JSON" -> Fail }
        * Ok<Json> => TestResult { Pass() }
    )
}

JsonAcceptsNull = () => TestResult {
    "null" -> Json -> (
        * Err<MalformedJson> => TestResult { "\"null\" should validate as JSON" -> Fail }
        * Ok<Json> => TestResult { Pass() }
    )
}

JsonAcceptsNumber = () => TestResult {
    "-1.5e10" -> Json -> (
        * Err<MalformedJson> => TestResult { "\"-1.5e10\" should validate as JSON" -> Fail }
        * Ok<Json> => TestResult { Pass() }
    )
}

JsonRejectsMalformedNumber = () => TestResult {
    "1." -> Json -> (
        * Err<MalformedJson> => TestResult { Pass() }
        * Ok<Json> => TestResult {
            "\"1.\" should not validate (missing fractional digits)" -> Fail
        }
    )
}

ToJsonFalse = () => TestResult {
    False()
        -> ToJson
        -> Eq("false")
        -> TestResult
}

ToJsonFloat = () => TestResult {
    1.5
        -> ToJson
        -> Eq("1.5")
        -> TestResult
}

ToJsonInt = () => TestResult {
    42
        -> ToJson
        -> Eq("42")
        -> TestResult
}

ToJsonStringEscapes = () => TestResult {
    "a\"b\\c"
        -> ToJson
        -> Eq("\"a\\\"b\\\\c\"")
        -> TestResult
}

ToJsonStringPlain = () => TestResult {
    "hi"
        -> ToJson
        -> Eq("\"hi\"")
        -> TestResult
}

ToJsonTrue = () => TestResult {
    True()
        -> ToJson
        -> Eq("true")
        -> TestResult
}
