testJsonDecodeEscapes = () => TestResult {
    "\"esc \\\" quote\""
        -> Json?
        -> Decoded?
        -> Eq("esc \" quote")
        -> TestResult("Decoded unescapes an embedded quote")
}

testJsonDecodePlain = () => TestResult {
    "\"gpt-4\""
        -> Json?
        -> Decoded?
        -> Eq("gpt-4")
        -> TestResult("Decoded unwraps a quoted JSON string")
}

testJsonFieldExtract = () => TestResult {
    "{\"model\":\"gpt-4\",\"stream\":true}"
        -> Json?
        -> Field("model")?
        -> Decoded?
        -> Eq("gpt-4")
        -> TestResult("Field extracts and Decoded reads a string member")
}

testJsonInvalidRejected = () => TestResult {
    "{oops" -> Json -> (
        * Err<MalformedJson> => TestResult { True() -> TestResult("malformed JSON is rejected") }
        * Ok<Json> => TestResult { False() -> TestResult("\"{oops\" should not validate") }
    )
}

testToJsonBoolFalse = () => TestResult {
    False()
        -> ToJson
        -> Eq("false")
        -> TestResult("ToJson renders False as false")
}

testToJsonBoolTrue = () => TestResult {
    True()
        -> ToJson
        -> Eq("true")
        -> TestResult("ToJson renders True as true")
}

testToJsonFloat = () => TestResult {
    1.5
        -> ToJson
        -> Eq("1.5")
        -> TestResult("ToJson renders a Float as a JSON number")
}

testToJsonInt = () => TestResult {
    42
        -> ToJson
        -> Eq("42")
        -> TestResult("ToJson renders an Int as its decimal digits")
}

testToJsonStringEscapes = () => TestResult {
    "a\"b\\c"
        -> ToJson
        -> Eq("\"a\\\"b\\\\c\"")
        -> TestResult("ToJson quotes a String and escapes quote and backslash")
}

testToJsonStringPlain = () => TestResult {
    "hi"
        -> ToJson
        -> Eq("\"hi\"")
        -> TestResult("ToJson wraps a plain String in quotes")
}
