MapContainsFindsKey = TestResult

Unit => MapContainsFindsKey {
    Map()
        -> Inserted("a" * "1")
        -> Contains("a")
        -> TestResult
}

MapContainsRejectsAbsent = TestResult

Unit => MapContainsRejectsAbsent {
    Map()
        -> Inserted("a" * "1")
        -> Contains("z")
        -> Not
        -> TestResult
}

MapInsertedRecursesPastMultipleNonMatchingKeys = TestResult

Unit => MapInsertedRecursesPastMultipleNonMatchingKeys {
    Map()
        -> Inserted("a" * "1")
        -> Inserted("b" * "2")
        -> Inserted("c" * "3")
        -> Inserted("d" * "4")
        -> Keys
        -> Json
        -> Eq("[a,b,c,d]")
        -> TestResult
}

MapKeysSorted = TestResult

Unit => MapKeysSorted {
    Map()
        -> Inserted("b" * "2")
        -> Inserted("a" * "1")
        -> Keys
        -> Json
        -> Eq("[a,b]")
        -> TestResult
}

MapLengthCountsKeys = TestResult

Unit => MapLengthCountsKeys {
    Map()
        -> Inserted("b" * "2")
        -> Inserted("a" * "1")
        -> Length
        -> Eq(2)
        -> TestResult
}

MapReinsertOverwrites = TestResult

Unit => MapReinsertOverwrites {
    Map() -> Inserted("a" * "1") -> Inserted("a" * "2") -> Value("a") -> (
        * None => TestResult { "key a should be present" -> Fail }
        * Some<Value> => TestResult { Value -> Eq("2") -> TestResult }
    )
}

MapRemovedDropsKey = TestResult

Unit => MapRemovedDropsKey {
    Map()
        -> Inserted("a" * "1")
        -> Inserted("b" * "2")
        -> Removed("a")
        -> Keys
        -> Json
        -> Eq("[b]")
        -> TestResult
}

MapRemovedOnEmptyIsNoOp = TestResult

Unit => MapRemovedOnEmptyIsNoOp {
    Map()
        -> Removed("a")
        -> Length
        -> Eq(0)
        -> TestResult
}

MapRemovedRecursesPastNonMatchingKey = TestResult

Unit => MapRemovedRecursesPastNonMatchingKey {
    Map()
        -> Inserted("a" * "1")
        -> Inserted("b" * "2")
        -> Removed("b")
        -> Keys
        -> Json
        -> Eq("[a]")
        -> TestResult
}

MapValueAbsent = TestResult

Unit => MapValueAbsent {
    Map() -> Inserted("a" * "1") -> Value("z") -> (
        * None => TestResult { Pass() }
        * Some<Value> => TestResult { "key z should be absent" -> Fail }
    )
}

MapValuePresent = TestResult

Unit => MapValuePresent {
    Map() -> Inserted("a" * "1") -> Value("a") -> (
        * None => TestResult { "key a should be present" -> Fail }
        * Some<Value> => TestResult { Value -> Eq("1") -> TestResult }
    )
}

MapValuesOrderedByKey = TestResult

Unit => MapValuesOrderedByKey {
    Map()
        -> Inserted("b" * "2")
        -> Inserted("a" * "1")
        -> Values
        -> Json
        -> Eq("[1,2]")
        -> TestResult
}
