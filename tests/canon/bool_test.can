AndOfFalseIsFalse = TestResult

Unit => AndOfFalseIsFalse {
    True()
        -> And(False())
        -> Not
        -> TestResult
}

AndOfTruesIsTrue = TestResult

Unit => AndOfTruesIsTrue {
    True()
        -> And(True())
        -> TestResult
}

AndShortCircuitsOnFalse = TestResult

Unit => AndShortCircuitsOnFalse {
    False()
        -> And(True())
        -> Not
        -> TestResult
}

NotOfFalseIsTrue = TestResult

Unit => NotOfFalseIsTrue {
    False()
        -> Not
        -> TestResult
}

NotOfTrueIsFalse = TestResult

Unit => NotOfTrueIsFalse {
    True()
        -> Not
        -> Not
        -> TestResult
}

OrOfFalsesIsFalse = TestResult

Unit => OrOfFalsesIsFalse {
    False()
        -> Or(False())
        -> Not
        -> TestResult
}

OrShortCircuitsOnTrue = TestResult

Unit => OrShortCircuitsOnTrue {
    True()
        -> Or(False())
        -> TestResult
}

OrWithTrueIsTrue = TestResult

Unit => OrWithTrueIsTrue {
    False()
        -> Or(True())
        -> TestResult
}
