package wasi:clocks@0.3.0-rc-2026-03-15;

/// A minimal monotonic-clock WIT for exercising `oneway gen-bindings`.
interface monotonic-clock {
    /// An instant in time, in nanoseconds.
    type instant = u64;

    /// Resolution, in nanoseconds.
    type duration = u64;

    /// Read the monotonic clock.
    now: func() -> instant;

    /// Read the clock resolution.
    get-resolution: func() -> duration;
}
