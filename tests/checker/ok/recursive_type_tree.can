Branch = Left * Right * Value

Described = String

Leaf = Unit

Left = Tree

Right = Tree

Tree = Branch + Leaf

Value = Int

Tree => Described {
    Tree -> (
        * Branch => Described { "branch" }
        * Leaf => Described { "leaf" }
    )
}

Unit => Program {
    Leaf()
        -> Described
        -> Print
}
