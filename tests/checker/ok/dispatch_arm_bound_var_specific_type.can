JsonEntry = String

JsonMissing = String

JsonObject = JsonEntry

JsonValue = JsonMissing + JsonObject

describe = (JsonValue) => Unit {
    JsonValue.(
        * JsonMissing => Unit { "missing" -> Print }
        * JsonObject => Unit { JsonObject.extract() -> Print }
    )
}

extract = (JsonObject) => String {
    "extracted"
}

main = () => Unit {
    "ok" -> Print
}
