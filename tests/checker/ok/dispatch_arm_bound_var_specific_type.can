Described = Unit

Extracted = String

JsonEntry = String

JsonMissing = String

JsonObject = JsonEntry

JsonValue = JsonMissing + JsonObject

JsonValue => Described {
    JsonValue -> (
        * JsonMissing => Described { "missing" -> Print }
        * JsonObject => Described { JsonObject -> Extracted -> Print }
    )
}

JsonObject => Extracted {
    "extracted"
}

Unit => Program {
    "payload"
        -> JsonEntry
        -> JsonObject
        -> Described
    "ok" -> Print
}
