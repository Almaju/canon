Classified = String

Path = String

Routed = String

Int => Classified {
    Int -> (
        * 0 => Classified { "zero" }
        * 1 => Classified { "one" }
        * Int => Classified { "many" }
    )
}

Path => Routed {
    Path -> (
        * "/" => Routed { "home" }
        * "/notes" => Routed { "index" }
        * Path => Routed { "not found" }
    )
}

Unit => Program {
    "/notes"
        -> Path
        -> Routed
        -> Print
    2
        -> Classified
        -> Print
}
