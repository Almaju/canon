Birthday = String

Equality = Bool

OtherUser = User

User = Birthday * Username

Username = String

OtherUser * User => Equality {
    True()
}

Unit => Program {
    "1990"
        -> Birthday
        -> User("alice" -> Username)
        -> Equality("1991" -> Birthday -> User("bob" -> Username) -> OtherUser)
    "compared" -> Print
}
