Birthday = String

OtherUser = User

User = Birthday * Username

Username = String

Equality = (OtherUser * User) => Bool {
    True()
}

Unit => Program {
    "1990"
        -> Birthday
        -> User("alice" -> Username)
        -> Equality("1991" -> Birthday -> User("bob" -> Username) -> OtherUser)
    "compared" -> Print
}
