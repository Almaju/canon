Described = String

Equal = Unit

Greater = Unit

Less = Unit

Ord = Equal
  + Greater
  + Less

Ord => Described {
    Ord -> (
        * Equal => Described { "equal" }
        * Greater => Described { "greater" }
        * Less => Described { "less" }
    )
}

Unit => Program {
    Equal()
        -> Described
        -> Print
}
