Equal = Unit

Greater = Unit

Less = Unit

Ord = Equal
  + Greater
  + Less

Described = (Ord) => String {
    Ord -> (
        * Equal => String { "equal" }
        * Greater => String { "greater" }
        * Less => String { "less" }
    )
}

Unit => Program {
    Equal()
        -> Described
        -> Print
}
