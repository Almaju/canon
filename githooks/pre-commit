#!/usr/bin/env sh
#
# pre-commit hook for oneway
#
# Runs before every commit to make sure:
#   1. cargo test passes
#   2. all examples compile and run successfully (via the embedded
#      wasmtime — `oneway run` produces no native binary)
#
# Install with:  just install-hooks
# Bypass once:   git commit --no-verify

set -e

echo "=== pre-commit: cargo fmt --check ==="
cargo fmt --check
echo "✓ formatting clean"

echo ""
echo "=== pre-commit: cargo clippy ==="
cargo clippy --quiet -- -D warnings
echo "✓ clippy clean"

echo ""
echo "=== pre-commit: cargo test ==="
cargo test --quiet
echo "✓ tests passed"

echo ""
echo "=== pre-commit: building and running all examples ==="

pass=0
fail=0
skip=0

for f in examples/*.ow examples/*/main.ow; do
    [ -f "$f" ] || continue
    if [ "$(basename "$f")" = "main.ow" ]; then
        label=$(basename "$(dirname "$f")")
    else
        label=$(basename "$f" .ow)
    fi

    printf "  %-20s" "$label"

    # Skip examples that do not pass the checker (documented codegen gaps)
    if ! cargo run --quiet -- check "$f" >/dev/null 2>&1; then
        echo "·  (skip — does not compile yet)"
        skip=$((skip + 1))
        continue
    fi

    # Run via the embedded WASM runtime with a 5s timeout (servers are
    # long-running by design and are reported as skipped, not failed).
    tmpout=$(mktemp)
    cargo run --quiet -- run "$f" > "$tmpout" 2>&1 &
    pid=$!
    i=0; timed_out=0
    while [ $i -lt 5 ] && kill -0 "$pid" 2>/dev/null; do
        sleep 1; i=$((i + 1))
    done
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null; wait "$pid" 2>/dev/null
        timed_out=1
    else
        wait "$pid"; rc=$?
    fi
    rm -f "$tmpout"

    if [ "$timed_out" -eq 1 ]; then
        echo "·  (skip — long-running)"
        skip=$((skip + 1))
    elif [ "$rc" -eq 0 ]; then
        echo "✓"
        pass=$((pass + 1))
    else
        echo "✗  (runtime error)"
        fail=$((fail + 1))
    fi
done

echo ""
echo "${pass} passed, ${fail} failed, ${skip} skipped"

if [ "$fail" -gt 0 ]; then
    echo "✗ ${fail} example(s) failed — commit aborted"
    echo "  Use 'git commit --no-verify' to bypass this check."
    exit 1
fi

echo "✓ all examples passed"
