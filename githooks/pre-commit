#!/usr/bin/env sh
#
# pre-commit hook for oneway
#
# Runs before every commit to make sure:
#   1. cargo test passes
#   2. all examples compile and run successfully
#
# Install with:  just install-hooks
# Bypass once:   git commit --no-verify

set -e

echo "=== pre-commit: running cargo test ==="
cargo test --quiet
echo "✓ tests passed"

echo ""
echo "=== pre-commit: building and running all examples ==="

fail=0

for f in examples/*.ow examples/*/main.ow; do
    [ -f "$f" ] || continue
    dir=$(dirname "$f")
    if [ "$(basename "$f")" = "main.ow" ]; then
        label=$(basename "$(dirname "$f")")
        stem="main"
    else
        stem=$(basename "$f" .ow)
        label="$stem"
    fi
    # Binary is placed inside .oneway/<stem>/<stem> by `oneway build`
    binpath="$dir/.oneway/$stem/$stem"

    printf "  %-20s" "$label"

    # Compile
    if ! cargo run --quiet -- build "$f" >/dev/null 2>&1; then
        echo "✗  (compile error)"
        fail=$((fail + 1))
        continue
    fi

    # Run with a 5-second timeout (long-running servers are skipped)
    tmpout=$(mktemp)
    "$binpath" > "$tmpout" 2>&1 &
    pid=$!
    i=0; timed_out=0
    while [ $i -lt 5 ] && kill -0 "$pid" 2>/dev/null; do
        sleep 1; i=$((i + 1))
    done
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null; wait "$pid" 2>/dev/null
        timed_out=1
    else
        wait "$pid"; rc=$?
    fi
    rm -f "$tmpout"

    if [ "$timed_out" -eq 1 ]; then
        echo "·  (skip — long-running)"
    elif [ "$rc" -eq 0 ]; then
        echo "✓"
    else
        echo "✗  (runtime error)"
        fail=$((fail + 1))
    fi
done

echo ""

if [ "$fail" -gt 0 ]; then
    echo "✗ ${fail} example(s) failed — commit aborted"
    echo "  Use 'git commit --no-verify' to bypass this check."
    exit 1
fi

echo "✓ all examples passed"
