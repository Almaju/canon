{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Canon",
  "scopeName": "source.canon",
  "fileTypes": ["can"],
  "patterns": [
    { "include": "#strings" },
    { "include": "#format-strings" },
    { "include": "#numbers" },
    { "include": "#function-def" },
    { "include": "#type-def" },
    { "include": "#builtin-types" },
    { "include": "#method-call" },
    { "include": "#function-call" },
    { "include": "#types" },
    { "include": "#variables" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "strings": {
      "name": "string.quoted.double.canon",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.canon" }
      },
      "end": "\"|$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.canon" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.canon",
          "match": "\\\\(\\\\|\"|n|r|t|0|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})"
        },
        {
          "name": "invalid.illegal.escape.canon",
          "match": "\\\\."
        }
      ]
    },
    "format-strings": {
      "name": "string.interpolated.canon",
      "begin": "`",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.canon" }
      },
      "end": "`",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.canon" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.canon",
          "match": "\\\\(\\\\|`|n|r|t|0|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})|\\{\\{|\\}\\}"
        },
        {
          "name": "meta.embedded.line.canon",
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.interpolation.begin.canon" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.canon" }
          },
          "patterns": [{ "include": "source.canon" }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.canon",
          "match": "(?<![A-Za-z0-9_])-?[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.canon",
          "match": "(?<![A-Za-z0-9_])-?[0-9]+\\b"
        }
      ]
    },
    "function-def": {
      "match": "^\\s*(?:([A-Z][A-Za-z0-9_]*)\\s*\\.\\s*)?([a-z_][A-Za-z0-9_]*)\\s*(=)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.type.canon" },
        "2": { "name": "entity.name.function.canon" },
        "3": { "name": "keyword.operator.assignment.canon" }
      }
    },
    "type-def": {
      "match": "^\\s*([A-Z][A-Za-z0-9_]*)\\s*(=)",
      "captures": {
        "1": { "name": "entity.name.type.canon" },
        "2": { "name": "keyword.operator.assignment.canon" }
      }
    },
    "builtin-types": {
      "name": "support.type.builtin.canon",
      "match": "\\b(Bool|Byte|Bytes|Err|False|Float|Future|Handle|Html|Int|Json|List|Network|Never|None|Ok|Option|Result|Some|Stderr|Stdin|Stdout|Stream|String|True|Unit)\\b"
    },
    "method-call": {
      "match": "(?<=\\.)([a-z_][A-Za-z0-9_]*)(?=\\s*\\()",
      "name": "entity.name.function.method.canon"
    },
    "function-call": {
      "match": "\\b([a-z_][A-Za-z0-9_]*)(?=\\s*\\()",
      "name": "entity.name.function.call.canon"
    },
    "types": {
      "name": "entity.name.type.canon",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "variables": {
      "name": "variable.other.canon",
      "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.canon",
          "match": "=>|->"
        },
        {
          "name": "keyword.operator.canon",
          "match": "[=+*?^]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.canon",
          "match": "[(){}\\[\\]<>]"
        },
        {
          "name": "punctuation.delimiter.canon",
          "match": "[.,:]"
        }
      ]
    }
  }
}
