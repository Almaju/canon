IpAddress = wasi/sockets/types/IpAddress

ErrorCode = ErrorCodeAccessDenied
  + ErrorCodeInvalidArgument
  + ErrorCodeNameUnresolvable
  + ErrorCodeOther
  + ErrorCodePermanentResolverFailure
  + ErrorCodeTemporaryResolverFailure

ErrorCodeAccessDenied = Unit

ErrorCodeInvalidArgument = Unit

ErrorCodeNameUnresolvable = Unit

ErrorCodeOther = Option<String>

ErrorCodePermanentResolverFailure = Unit

ErrorCodeTemporaryResolverFailure = Unit
