                            Json -> ByteAt(Int -> Sum(2)) -> IsHex -> (
                                * False => Result<UnescapedUnicode, MalformedJson> {
                                    MalformedJson("bad \\u escape") -> Err
                                }
                                * True => Result<UnescapedUnicode, MalformedJson> {
                                    Json -> ByteAt(Int -> Sum(3)) -> IsHex -> (
                                        * False => Result<UnescapedUnicode, MalformedJson> {
                                            MalformedJson("bad \\u escape") -> Err
                                        }
                                        * True => Result<UnescapedUnicode, MalformedJson> {
                                            Int
                                                -> Sum(4)
                                                -> UnescapedTail(Json)
                                                -> Prefixed(Json -> ByteAt(Int) -> HexVal -> Product(4096) -> Sum(Json -> ByteAt(Int -> Sum(1)) -> HexVal -> Product(256)) -> Sum(Json -> ByteAt(Int -> Sum(2)) -> HexVal -> Product(16)) -> Sum(Json -> ByteAt(Int -> Sum(3)) -> HexVal) -> Utf8 -> Prefix)
                                        }
                                    )
                                }
                            )
                        }
                    )
                }
            )
        }
        * True => Result<UnescapedUnicode, MalformedJson> {
            MalformedJson("truncated \\u escape") -> Err
        }
    )
}

Int => Utf8 {
    Int -> Lt(128) -> (
        * False => Utf8 {
            Int -> Lt(2048) -> (
                * False => Utf8 {
                    Int -> Ge(55296) -> (
                        * False => Utf8 { Int -> Utf8Three }
                        * True => Utf8 {
                            Int -> Le(57343) -> (
                                * False => Utf8 { Int -> Utf8Three }
                                * True => Utf8 { Utf8Three(65533) }
                            )
                        }
                    )
                }
                * True => Utf8 {
                    192
                        -> Sum(Int -> Quotient(64))
                        -> Byte
                        -> String
                        -> Joined(128 -> Sum(Int -> Remainder(64)) -> Byte -> String)
                }
            )
        }
        * True => Utf8 { Int -> Byte -> String }
    )
}

Int => Utf8Three {
    224
        -> Sum(Int -> Quotient(4096))
        -> Byte
        -> String
        -> Joined(128 -> Sum(Int -> Quotient(64) -> Remainder(64)) -> Byte -> String)
        -> Joined(128 -> Sum(Int -> Remainder(64)) -> Byte -> String)
}

String => Validated {
    1
        -> ParsedValue(String)
        -> CheckedTrailing(String)
}

Utf8Three = Utf8

Validated = ParseStep

ValueEnded = Json

ValueParsed = Json

ValueStart = Int

ParseStep * ValueStart * KeyEq * Json * String => Result<ValueEnded, MalformedJson> {
    ParseStep -> (
        * ParseFail => Result<ValueEnded, MalformedJson> {
            ParseFail.String
                -> MalformedJson
                -> Err
        }
        * ParsePos => Result<ValueEnded, MalformedJson> {
            KeyEq -> (
                * False => Result<ValueEnded, MalformedJson> {
                    ParsePos.Int
                        -> AfterWs(Json)
                        -> TailChecked(Json * String)
                }
                * True => Result<ValueEnded, MalformedJson> {
                    Json
                        -> Substring(ValueStart -> From * ParsePos.Int -> Difference(1) -> To)
                        -> Ok
                }
            )
        }
    )
}

Int * KeyEq * Json * String => Result<ValueParsed, MalformedJson> {
    Int
        -> DispatchedValue(Json)
        -> ValueEnded(Int -> ValueStart * KeyEq * Json * String)
}
