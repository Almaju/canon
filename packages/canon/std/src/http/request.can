Request = Handle

bindings "wasi:http/types@0.3.0-rc-2026-03-15#[method]request.get-method"

method = (Request) -> String

bindings "wasi:http/types@0.3.0-rc-2026-03-15#[method]request.get-path-with-query"

path = (Request) -> Option<String>

bindings "wasi:http/types@0.3.0-rc-2026-03-15#[method]request.consume-body"

body = (Request) -> Future<Result<String, HttpError>>
