And = Bool

Not = Bool

Or = Bool

OtherBool = Bool

Bool * OtherBool => And {
    Bool -> (
        * False => And { False() }
        * True => And { OtherBool }
    )
}

Bool => Not {
    Bool -> (
        * False => Not { True() }
        * True => Not { False() }
    )
}

Bool * OtherBool => Or {
    Bool -> (
        * False => Or { OtherBool }
        * True => Or { True() }
    )
}
