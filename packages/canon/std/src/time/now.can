DatePart = String

Now = String

TimePart = String

Civil => DatePart {
    `{Civil.Year -> Padded(4)}-{Civil.Month -> Padded(2)}-{Civil.Day -> Padded(2)}`
}

Unit => Now {
    Unix() -> Now
}

Unix => Now {
    `{Unix -> Date -> DatePart}T{Unix -> TimePart}Z`
}

Unix => TimePart {
    `{Unix -> Hour -> Padded(2)}:{Unix -> Minute -> Padded(2)}:{Unix -> Second -> Padded(2)}`
}
