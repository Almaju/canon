}

Int * String => IsPara {
    Int -> Gt(String -> Length) -> (
        * False => IsPara {
            String -> ByteAt(Int) -> Eq(10) -> (
                * False => IsPara {
                    Int -> IsItem(String) -> (
                        * False => IsPara {
                            Int -> IsFence(String) -> (
                                * False => IsPara {
                                    String -> ByteAt(Int) -> Eq(35) -> (
                                        * False => IsPara { True() }
                                        * True => IsPara {
                                            Int
                                                -> Sum(Int -> HashCount(String))
                                                -> Gt(String -> Length) -> (
                                                * False => IsPara {
                                                    String
                                                        -> ByteAt(Int -> Sum(Int -> HashCount(String)))
                                                        -> Eq(32) -> (
                                                        * False => IsPara { True() }
                                                        * True => IsPara { False() }
                                                    )
                                                }
                                                * True => IsPara { True() }
                                            )
                                        }
                                    )
                                }
                                * True => IsPara { False() }
                            )
                        }
                        * True => IsPara { False() }
                    )
                }
                * True => IsPara { False() }
            )
        }
        * True => IsPara { False() }
    )
}

Int * String => LineEnd {
    Int -> Gt(String -> Length) -> (
        * False => LineEnd {
            String -> ByteAt(Int) -> Eq(10) -> (
                * False => LineEnd { Int -> Sum(1) -> LineEnd(String) }
                * True => LineEnd { Int }
            )
        }
        * True => LineEnd { Int }
    )
}

Int * String => ListEnd {
    Int -> IsItem(String) -> (
        * False => ListEnd { Int }
        * True => ListEnd { Int -> LineEnd(String) -> Sum(1) -> ListEnd(String) }
    )
}

Int * String => ListItems {
    Int -> IsItem(String) -> (
        * False => ListItems { "" }
        * True => ListItems {
            Int -> Sum(2) -> Gt(Int -> LineEnd(String) -> Difference(1)) -> (
                * False => ListItems {
                    "<li>"
                        -> Joined(1 -> Inline(String -> Substring(Int -> Sum(2) -> From * Int -> LineEnd(String) -> Difference(1) -> To)))
                        -> Joined("</li>")
                        -> Joined(Int -> LineEnd(String) -> Sum(1) -> ListItems(String))
                }
                * True => ListItems {
                    "<li></li>" -> Joined(Int -> LineEnd(String) -> Sum(1) -> ListItems(String))
                }
            )
        }
    )
}

Int * String => ParaBody {
    1
        -> Inline(String -> Substring(Int -> From * Int -> LineEnd(String) -> Difference(1) -> To))
        -> Joined(Int -> LineEnd(String) -> Sum(1) -> IsPara(String) -> ( * False => Frag { "" } * True => Frag { " " -> Joined(Int -> LineEnd(String) -> Sum(1) -> ParaBody(String)) }))
}

Int * String => ParaEnd {
    Int -> IsPara(String) -> (
        * False => ParaEnd { Int }
        * True => ParaEnd { Int -> LineEnd(String) -> Sum(1) -> ParaEnd(String) }
    )
}

Int * String => RenderedBlocks {
    Int -> Gt(String -> Length) -> (
        * False => RenderedBlocks {
            String -> ByteAt(Int) -> Eq(10) -> (
                * False => RenderedBlocks {
                    Int -> IsFence(String) -> (
                        * False => RenderedBlocks {
                            Int -> IsItem(String) -> (
                                * False => RenderedBlocks { Int -> RenderedNonList(String) }
                                * True => RenderedBlocks { Int -> RenderedList(String) }
                            )
                        }
                        * True => RenderedBlocks { Int -> RenderedFence(String) }
                    )
                }
                * True => RenderedBlocks { Int -> Sum(1) -> RenderedBlocks(String) }
            )
        }
        * True => RenderedBlocks { "" }
    )
}

Int * String => RenderedFence {
    "<pre><code>"
        -> Joined(Int -> LineEnd(String) -> Sum(1) -> FenceBody(String))
        -> Joined("</code></pre>")
        -> Joined(Int -> LineEnd(String) -> Sum(1) -> FenceEnd(String) -> RenderedBlocks(String))
}

Int * String => RenderedHeading {
    Int -> Sum(Int -> HashCount(String)) -> Sum(1) -> Gt(Int -> LineEnd(String) -> Difference(1)) -> (
        * False => RenderedHeading {
            Int
                -> HashCount(String)
                -> HeadingHtml(1 -> Inline(String -> Substring(Int -> Sum(Int -> HashCount(String)) -> Sum(1) -> From * Int -> LineEnd(String) -> Difference(1) -> To)))
                -> Joined(Int -> LineEnd(String) -> Sum(1) -> RenderedBlocks(String))
        }
        * True => RenderedHeading {
            Int
                -> HashCount(String)
                -> HeadingHtml("")
                -> Joined(Int -> LineEnd(String) -> Sum(1) -> RenderedBlocks(String))
        }
    )
}

Int * String => RenderedList {
    "<ul>"
        -> Joined(Int -> ListItems(String))
        -> Joined("</ul>")
        -> Joined(Int -> ListEnd(String) -> RenderedBlocks(String))
}

Int * String => RenderedNonList {
    String -> ByteAt(Int) -> Eq(35) -> (
