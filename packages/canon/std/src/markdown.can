Int * String => FenceBody {
    Int -> Gt(String -> Length) -> (
        * False => FenceBody {
            Int -> IsFence(String) -> (
                * False => FenceBody {
                    Int -> LineEnd(String) -> Gt(Int) -> (
                        * False => FenceBody {
                            "\n" -> Joined(Int -> LineEnd(String) -> Sum(1) -> FenceBody(String))
                        }
                        * True => FenceBody {
                            String
                                -> Substring(Int -> From * Int -> LineEnd(String) -> Difference(1) -> To)
                                -> Escaped
                                -> Joined("\n")
                                -> Joined(Int -> LineEnd(String) -> Sum(1) -> FenceBody(String))
                        }
                    )
                }
                * True => FenceBody { "" }
            )
        }
        * True => FenceBody { "" }
    )
}

Int * String => FenceEnd {
    Int -> Gt(String -> Length) -> (
        * False => FenceEnd {
            Int -> IsFence(String) -> (
                * False => FenceEnd { Int -> LineEnd(String) -> Sum(1) -> FenceEnd(String) }
                * True => FenceEnd { Int -> LineEnd(String) -> Sum(1) }
            )
        }
        * True => FenceEnd { Int }
    )
}

Int * String => HashCount {
    Int -> Gt(String -> Length) -> (
        * False => HashCount {
            String -> ByteAt(Int) -> Eq(35) -> (
                * False => HashCount { 0 }
                * True => HashCount { Int -> Sum(1) -> HashCount(String) -> Sum(1) }
            )
        }
        * True => HashCount { 0 }
    )
}

Int * String => HeadingHtml {
    Int -> Eq(1) -> (
        * False => HeadingHtml {
            Int -> Eq(2) -> (
                * False => HeadingHtml { "<h3>" -> Joined(String) -> Joined("</h3>") }
                * True => HeadingHtml { "<h2>" -> Joined(String) -> Joined("</h2>") }
            )
        }
        * True => HeadingHtml { "<h1>" -> Joined(String) -> Joined("</h1>") }
    )
}

Markdown => Html {
    1
        -> RenderedBlocks(Markdown)
        -> Html
}

Int * String => Inline {
    Int -> Gt(String -> Length) -> (
        * False => Inline {
            String -> ByteAt(Int) -> Eq(96) -> (
                * False => Inline {
                    String -> ByteAt(Int) -> Eq(42) -> (
                        * False => Inline {
                            String
                                -> Substring(Int -> From * Int -> To)
                                -> Escaped
                                -> Joined(Int -> Sum(1) -> Inline(String))
                        }
                        * True => Inline {
                            Int -> Sum(1) -> Gt(String -> Length) -> (
                                * False => Inline {
                                    String -> ByteAt(Int -> Sum(1)) -> Eq(42) -> (
                                        * False => Inline {
                                            "*" -> Joined(Int -> Sum(1) -> Inline(String))
                                        }
                                        * True => Inline {
                                            "<strong>"
                                                -> Joined(1 -> Inline(String -> Substring(Int -> Sum(2) -> From * Int -> Sum(2) -> StarClose(String) -> Difference(1) -> To)))
                                                -> Joined("</strong>")
                                                -> Joined(Int -> Sum(2) -> StarClose(String) -> Sum(2) -> Inline(String))
                                        }
                                    )
                                }
                                * True => Inline { "*" }
                            )
                        }
                    )
                }
                * True => Inline {
                    "<code>"
                        -> Joined(String -> Substring(Int -> Sum(1) -> From * Int -> Sum(1) -> TickClose(String) -> Difference(1) -> To) -> Escaped)
                        -> Joined("</code>")
                        -> Joined(Int -> Sum(1) -> TickClose(String) -> Sum(1) -> Inline(String))
                }
            )
        }
        * True => Inline { "" }
    )
}

Int * String => IsFence {
    Int -> Sum(2) -> Gt(String -> Length) -> (
        * False => IsFence {
            String -> ByteAt(Int) -> Eq(96) -> (
                * False => IsFence { False() }
                * True => IsFence {
                    String -> ByteAt(Int -> Sum(1)) -> Eq(96) -> (
                        * False => IsFence { False() }
                        * True => IsFence { String -> ByteAt(Int -> Sum(2)) -> Eq(96) }
                    )
                }
            )
        }
        * True => IsFence { False() }
    )
}

Int * String => IsItem {
    Int -> Sum(1) -> Gt(String -> Length) -> (
        * False => IsItem {
            String -> ByteAt(Int) -> Eq(45) -> (
                * False => IsItem { False() }
                * True => IsItem { String -> ByteAt(Int -> Sum(1)) -> Eq(32) }
            )
