main = (Stdout) -> Unit {
    List(1, 2, 3)
        .length()
        .print(Stdout)
    List(10, 20, 30)
        .map((Int) -> Int { Int.mul(2) })
        .length()
        .print(Stdout)
    List(7, 8, 9).first().(
        * (None) -> Unit { "empty".print(Stdout) }
        * (Some<Int>) -> Unit { "non-empty".print(Stdout) }
    )
}
