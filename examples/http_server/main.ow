use HttpServer

main = (HttpServer * Stdout) -> Result<Unit, IoError> {
    "Starting server on port 3000...".print(Stdout)
    HttpServer.router()
    .get(RoutePath("/"), (HttpRequest) -> HttpResponse { HttpResponse("Hello from Oneway!") })
    .get(RoutePath("/health"), (HttpRequest) -> HttpResponse { HttpResponse("ok") })
    .post(RoutePath("/echo"), (HttpRequest) -> HttpResponse { HttpResponse("received") })
    .serve(Port(3000))
}
