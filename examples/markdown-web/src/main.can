Init = Page

Msg = String

Page = String

Update = Page

Page => Html {
    Styles()
        -> Joined("<div class=\"doc\"><nav><button data-msg=\"Show:intro\">Intro</button> <button data-msg=\"Show:guide\">Guide</button></nav><hr>")
        -> Joined(Page -> ( * "guide" => Html { Guide() -> Html } * String => Html { Intro() -> Html }))
        -> Joined("</div>")
        -> Html
}

Unit => Init {
    "intro" -> Page
}

Page * Msg => Update {
    Msg -> Substring(1 -> From * 5 -> To) -> (
        * "Show:" => Page { Msg -> Substring(6 -> From * Msg -> Length -> To) -> Page }
        * String => Page { Page }
    )
}
