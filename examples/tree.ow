Branch = Left * Right * Value

Left = Tree

Right = Tree

Tree = Branch + Leaf

Value = Int

describe = (Tree) -> String {
    Tree.(
        * (Branch) -> String { "branch" }
        * (Leaf) -> String { "leaf" }
    )
}

main = () -> Unit {
    Leaf()
        .describe()
        .print
    Branch(Left(Leaf()) * Right(Leaf()) * Value(7))
        .describe()
        .print
}
